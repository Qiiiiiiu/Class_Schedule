/**app.wxss — 深色工业风格主题 **/

/* ========== 基础重置 ========== */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

button {
  background: initial;
}

button:focus {
  outline: 0;
}

button::after {
  border: none;
}

page {
  background: #0f1419;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  --dark-bg:         #0f1419;
  --dark-surface:    #1a1f2e;
  --dark-card:       #23293a;
  --dark-border:     #2a3042;
  --primary-blue:    #3b82f6;
  --primary-cyan:    #06b6d4;
  --primary-purple:  #8b5cf6;
  --text-primary:    #f1f5f9;
  --text-secondary:  #94a3b8;
  --text-hint:       #64748b;
  --success:         #10b981;
  --warning:         #f59e0b;
  --danger:          #ef4444;
  --accent-green:    #10b981;
  --accent-red:      #ef4444;
}

/* ========== 深色主题阴影工具类 ========== */
.dark-card {
  background: linear-gradient(145deg, #23293a, #1a1f2e);
  border-radius: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.dark-card-hover:active {
  background: linear-gradient(145deg, #1e2433, #171c29);
  box-shadow: inset 0 4rpx 12rpx rgba(0, 0, 0, 0.4);
}

.dark-btn {
  background: linear-gradient(145deg, #3b82f6, #2563eb);
  color: #ffffff;
  border: none;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.3);
}

.dark-btn:active {
  box-shadow: inset 0 4rpx 8rpx rgba(0, 0, 0, 0.3);
}

.dark-input {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  color: #f1f5f9;
}

.dark-input:focus {
  border-color: #3b82f6;
  box-shadow: 0 0 0 2rpx rgba(59, 130, 246, 0.2);
}

/* ========== 星期选择器 (深色主题) ========== */
.weekday-item {
  background: rgba(255, 255, 255, 0.05) !important;
  color: #94a3b8 !important;
  border: 1rpx solid rgba(255, 255, 255, 0.1) !important;
  border-radius: 8rpx;
}

.weekday-item.selected {
  background: linear-gradient(145deg, #3b82f6, #2563eb) !important;
  color: #ffffff !important;
  border: none !important;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.4);
}

/* ========== 通用文本样式 ========== */
.text-primary {
  color: #f1f5f9;
}

.text-secondary {
  color: #94a3b8;
}

.text-hint {
  color: #64748b;
}

.text-success {
  color: #10b981;
}

.text-danger {
  color: #ef4444;
}

.text-warning {
  color: #f59e0b;
}
