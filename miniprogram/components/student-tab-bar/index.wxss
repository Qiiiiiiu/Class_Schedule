.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #1a1a2e;
  display: flex;
  padding-bottom: env(safe-area-inset-bottom);
  box-sizing: content-box;
  z-index: 999;
}

.tab-bar-border {
  background-color: rgba(255, 255, 255, 0.08);
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 1px;
  transform: scaleY(0.5);
}

.tab-bar-item {
  flex: 1;
  text-align: center;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-direction: column;
  height: 100rpx;
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 4rpx;
}

.tab-text {
  font-size: 20rpx;
  color: #666666;
}

.tab-text.active {
  color: #3b82f6;
}
