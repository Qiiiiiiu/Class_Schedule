.container {
  min-height: 100vh;
  background: #0f1419;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: stretch;
}

/* ===== 表单区块 ===== */
.form-section {
  background: linear-gradient(145deg, #23293a, #1a1f2e);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  width: 100%;
  box-sizing: border-box;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.form-section.locked {
  background: linear-gradient(145deg, #1e2433, #171c29);
  opacity: 0.8;
  box-shadow: inset 0 4rpx 12rpx rgba(0, 0, 0, 0.4);
}

.form-section.locked .section-title {
  color: #64748b;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #f1f5f9;
  display: block;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(59, 130, 246, 0.15);
}

.section-desc {
  font-size: 24rpx;
  color: #64748b;
  margin-top: 8rpx;
  display: block;
}

.form-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 30rpx;
  width: 100%;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  width: 160rpx;
  font-size: 28rpx;
  color: #94a3b8;
  flex-shrink: 0;
  text-align: right;
  padding-right: 20rpx;
  padding-top: 16rpx;
  font-weight: 500;
}

.content-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  min-width: 0;
}

.input {
  width: 100%;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #f1f5f9;
  box-sizing: border-box;
}

.input:focus {
  border-color: #3b82f6;
  box-shadow: 0 0 0 2rpx rgba(59, 130, 246, 0.2);
}

.input-disabled {
  background: rgba(255, 255, 255, 0.03) !important;
  color: #64748b;
  border-color: rgba(255, 255, 255, 0.05);
}

.price-input-wrap {
  display: flex;
  align-items: center;
  width: 100%;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  box-sizing: border-box;
}

.price-symbol {
  font-size: 28rpx;
  color: #64748b;
  padding-left: 24rpx;
  padding-right: 8rpx;
}

.price-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx 0 0;
  background: transparent;
  border-radius: 0;
  color: #f1f5f9;
}

.price-display-wrap {
  display: flex;
  align-items: center;
  width: 100%;
  height: 72rpx;
  background: rgba(59, 130, 246, 0.1);
  border: 1rpx solid rgba(59, 130, 246, 0.2);
  border-radius: 12rpx;
  box-sizing: border-box;
}

.price-display {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx 0 0;
  background: transparent;
  border-radius: 0;
  color: #3b82f6;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
}

.price-tip {
  font-size: 24rpx;
  color: #64748b;
  padding-right: 24rpx;
}

.picker-value {
  width: 100%;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #f1f5f9;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.time-picker {
  width: 100%;
  display: flex;
  align-items: center;
  /* justify-content: space-between; */
}



.time-separator {
  color: #64748b;
  font-size: 28rpx;
  width: 50rpx;
  text-align: center;
  flex-shrink: 0;
}

.switch-wrap {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.switch-label {
  font-size: 28rpx;
  color: #f1f5f9;
}

/* ===== 底部操作栏 ===== */
.form-actions {
  padding: 30rpx;
}

.save-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(145deg, #3b82f6, #2563eb);
  border: none;
  border-radius: 48rpx;
  font-size: 32rpx;
  color: #ffffff;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.4);
}

.save-btn:active {
  box-shadow: inset 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}

.cancel-btn {
  width: 100%;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 48rpx;
  font-size: 32rpx;
  color: #94a3b8;
}

.cancel-btn:active {
  background: rgba(255, 255, 255, 0.08);
}

/* ===== 学生列表容器 ===== */
.student-list-container {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.student-search-wrap {
  width: 100%;
}

.student-search-input {
  width: 100%;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #f1f5f9;
  box-sizing: border-box;
}

.search-placeholder {
  color: #64748b;
}

.student-scroll-list {
  max-height: 420rpx;
  width: 100%;
}

/* ===== 学生列表 ===== */
.student-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.student-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
}

.student-item.selected {
  background: rgba(59, 130, 246, 0.15);
  border-color: rgba(59, 130, 246, 0.3);
}

.student-item.disabled {
  opacity: 0.5;
  pointer-events: none;
}

.student-info {
  flex: 1;
}

.student-name {
  font-size: 28rpx;
  color: #f1f5f9;
  display: block;
  margin-bottom: 8rpx;
}

.student-phone {
  font-size: 24rpx;
  color: #64748b;
}

.student-check {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  font-size: 24rpx;
  background: rgba(255, 255, 255, 0.05);
  color: transparent;
}

.student-item.selected .student-check {
  background: linear-gradient(145deg, #3b82f6, #2563eb);
  color: #ffffff;
  border: none;
  box-shadow: 0 2rpx 8rpx rgba(59, 130, 246, 0.4);
}

.empty-tip {
  padding: 40rpx 0;
  text-align: center;
  color: #64748b;
  font-size: 28rpx;
}

/* ===== 星期选择器 ===== */
.weekday-picker {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  width: 100%;
  padding: 10rpx 0;
}

.weekday-item {
  width: calc((100% - 96rpx) / 7);
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #94a3b8;
  transition: all 0.2s;
}

.weekday-item:active {
  transform: scale(0.95);
}

.weekday-item.selected {
  background: linear-gradient(145deg, #3b82f6, #2563eb);
  color: #ffffff;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.4);
}

.weekday-item.disabled {
  opacity: 0.6;
}

.switch-wrap,
.time-picker,
.price-input-wrap {
  align-self: center;
}

.picker-value,
.input,
.price-input-wrap {
  align-self: stretch;
}

.repeat-count-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.repeat-count-input {
  width: 200rpx;
  text-align: center;
}

.repeat-count-tip {
  font-size: 22rpx;
  color: #64748b;
  margin-top: 8rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.section-badge {
  background: linear-gradient(145deg, #3b82f6, #2563eb);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(59, 130, 246, 0.3);
}

.badge-text {
  font-size: 22rpx;
  color: #ffffff;
}

.section-count {
  font-size: 24rpx;
  color: #64748b;
}

.lock-tip {
  font-size: 22rpx;
  color: #fca5a5;
  background: rgba(239, 68, 68, 0.12);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

/* ===== 子课程列表 ===== */
.child-course-list {
  margin-top: 10rpx;
}

.child-course-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
  margin-bottom: 15rpx;
}

.child-course-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.child-course-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #f1f5f9;
}

.child-course-schedule {
  font-size: 24rpx;
  color: #3b82f6;
}

.child-course-room {
  font-size: 22rpx;
  color: #64748b;
}

.child-course-price {
  font-size: 26rpx;
  color: #10b981;
  font-weight: 600;
}

.student-count-badge {
  display: flex;
  align-items: baseline;
  background: rgba(16, 185, 129, 0.12);
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
}

.count-num {
  font-size: 32rpx;
  font-weight: bold;
  color: #10b981;
  margin-right: 8rpx;
}

.count-label {
  font-size: 24rpx;
  color: #10b981;
}

.student-names-wrap {
  background: rgba(16, 185, 129, 0.12);
  padding: 12rpx 24rpx;
  border-radius: 16rpx;
  width: 100%;
  box-sizing: border-box;
}

.student-names {
  font-size: 26rpx;
  color: #10b981;
  line-height: 1.5;
}

.child-course-actions {
  display: flex;
  gap: 15rpx;
  margin-left: 20rpx;
}

.action-btn {
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.edit-btn {
  background: rgba(59, 130, 246, 0.15);
  color: #3b82f6;
}

.delete-btn {
  background: rgba(239, 68, 68, 0.15);
  color: #ef4444;
}

/* ===== 添加子课按钮 ===== */
.add-course-btn-wrap {
  margin-top: 20rpx;
}

.add-course-btn {
  width: 100%;
  height: 80rpx;
  font-size: 28rpx;
  border-radius: 40rpx;
  background: linear-gradient(145deg, #3b82f6, #2563eb);
  color: #ffffff;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.4);
}

.add-course-btn:active {
  box-shadow: inset 0 4rpx 8rpx rgba(0, 0, 0, 0.3);
}

/* ===== 弹窗 ===== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 650rpx;
  background: linear-gradient(145deg, #23293a, #1a1f2e);
  border-radius: 24rpx;
  overflow: hidden;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.4);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #f1f5f9;
}

.modal-close {
  font-size: 36rpx;
  color: #64748b;
  padding: 10rpx;
}

.modal-body {
  flex: 1;
  padding: 30rpx;
  overflow-y: auto;
}

.modal-footer {
  padding: 20rpx 30rpx 30rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.modal-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  border: none;
}

.modal-btn.confirm-btn {
  background: linear-gradient(145deg, #3b82f6, #2563eb);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.4);
}

.modal-btn.cancel-btn {
  background: rgba(255, 255, 255, 0.05);
  color: #94a3b8;
  margin-top: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.generated-content {
  width: 700rpx;
}

.generated-course-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.generated-course-item {
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
}

.generated-course-item .course-info {
  margin-bottom: 16rpx;
}

.generated-course-item .course-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #f1f5f9;
  display: block;
  margin-bottom: 8rpx;
}

.generated-course-item .course-schedule {
  font-size: 26rpx;
  color: #94a3b8;
}

.generated-course-item .course-detail {
  display: flex;
  gap: 30rpx;
}

.generated-course-item .course-room,
.generated-course-item .course-students {
  font-size: 24rpx;
  color: #64748b;
}

/* ===== 编辑子课程弹窗样式 ===== */
.edit-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.edit-modal-content {
  width: 85%;
  max-width: 650rpx;
  background: linear-gradient(145deg, #23293a, #1a1f2e);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.4);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.edit-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.edit-modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #f1f5f9;
}

.edit-modal-close {
  font-size: 36rpx;
  color: #64748b;
  padding: 10rpx;
}

.edit-modal-body {
  padding: 30rpx;
}

.edit-form-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.edit-label {
  font-size: 28rpx;
  color: #64748b;
}

.edit-picker-value {
  font-size: 28rpx;
  color: #ffffff;
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
}

.edit-time-picker {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.edit-time-separator {
  font-size: 28rpx;
  color: #64748b;
}

.edit-input {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #f1f5f9;
  padding: 12rpx 0;
}

.edit-modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx 30rpx;
}

.edit-modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.edit-modal-btn.cancel {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  color: #94a3b8;
}

.edit-modal-btn.save {
  background: linear-gradient(145deg, #10b981, #059669);
  color: #ffffff;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.3);
}

.edit-modal-btn.delete {
  background: rgba(239, 68, 68, 0.15);
  border: 1rpx solid rgba(239, 68, 68, 0.3);
  color: #ef4444;
}

/* ===== 课程日历视图 ===== */
.course-calendar-view {
  margin-top: 20rpx;
  background: rgba(255, 255, 255, 0.02);
  border-radius: 12rpx;
  overflow: hidden;
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: rgba(59, 130, 246, 0.08);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.calendar-nav {
  padding: 10rpx 20rpx;
}

.nav-btn {
  font-size: 32rpx;
  color: #3b82f6;
}

.calendar-title {
  font-size: 28rpx;
  color: #f1f5f9;
  font-weight: 600;
}

.view-toggle {
  padding: 10rpx 20rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
}

.toggle-text {
  font-size: 24rpx;
  color: #3b82f6;
}

.calendar-weekdays {
  display: flex;
  justify-content: space-around;
  padding: 15rpx 0;
  background: rgba(255, 255, 255, 0.03);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.weekday-item {
  flex: 1;
  text-align: center;
}

.weekday {
  font-size: 24rpx;
  color: #64748b;
}

.calendar-grid {
  display: flex;
  flex-direction: column;
}

.calendar-row {
  display: flex;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.04);
}

.calendar-row:last-child {
  border-bottom: none;
}

.calendar-day-cell {
  flex: 1;
  height: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 10rpx 4rpx;
  border-right: 1rpx solid rgba(255, 255, 255, 0.04);
  position: relative;
}

.calendar-day-cell:last-child {
  border-right: none;
}

.calendar-day-cell.other-month {
  opacity: 0.3;
}

.calendar-day-cell.today {
  background: rgba(59, 130, 246, 0.15);
}

.calendar-day-cell.has-course {
  background: rgba(59, 130, 246, 0.08);
}

.day-number {
  font-size: 28rpx;
  color: #94a3b8;
  margin-bottom: 6rpx;
}

.calendar-day-cell.today .day-number {
  color: #3b82f6;
  font-weight: bold;
}

.day-courses-mini {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  width: 100%;
  align-items: center;
}

.course-mini-tag {
  background: linear-gradient(145deg, #3b82f6, #2563eb);
  padding: 4rpx 8rpx;
  border-radius: 6rpx;
  max-width: 80%;
  overflow: hidden;
}

.course-mini-time {
  font-size: 20rpx;
  color: #ffffff;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ===== 日期课程列表弹窗样式 ===== */
.day-courses-list {
  padding: 0;
}

.day-course-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.day-course-item:last-child {
  border-bottom: none;
}

.day-course-time {
  width: 140rpx;
  flex-shrink: 0;
}

.time-text {
  font-size: 26rpx;
  color: #3b82f6;
  font-weight: 600;
}

.day-course-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.day-course-name {
  font-size: 28rpx;
  color: #f1f5f9;
}

.day-course-room {
  font-size: 24rpx;
  color: #64748b;
}

.day-course-delete {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  font-size: 32rpx;
}

/* ===== 明细列表样式 ===== */
.detail-list {
  padding: 10rpx;
}

.detail-course-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
  margin-bottom: 15rpx;
}

.detail-course-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.detail-course-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #f1f5f9;
}

.detail-course-schedule {
  font-size: 24rpx;
  color: #3b82f6;
}

.detail-course-room {
  font-size: 22rpx;
  color: #64748b;
}

.detail-course-actions {
  display: flex;
  gap: 15rpx;
  margin-left: 20rpx;
}

.detail-action-btn {
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.detail-action-btn.edit-btn {
  background: rgba(59, 130, 246, 0.15);
  color: #3b82f6;
}

.detail-action-btn.delete-btn {
  background: rgba(239, 68, 68, 0.15);
  color: #ef4444;
}

/* ===== 点选日期月历样式 ===== */
.select-calendar-view {
  width: 100%;
  background: rgba(255, 255, 255, 0.02);
  border-radius: 12rpx;
  overflow: hidden;
  margin-top: 10rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.select-calendar-day-cell {
  flex: 1;
  height: 90rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  border-right: 1rpx solid rgba(255, 255, 255, 0.04);
  box-sizing: border-box;
}

.select-calendar-day-cell:last-child {
  border-right: none;
}

.select-calendar-day-cell.other-month {
  opacity: 0.3;
}

.select-calendar-day-cell.today {
  border: 2rpx solid rgba(59, 130, 246, 0.5);
  border-radius: 8rpx;
}

.select-calendar-day-cell.selected {
  background: #3b82f6 !important;
  border-radius: 8rpx;
}

.select-calendar-day-cell.selected .day-number {
  color: #ffffff !important;
  font-weight: bold;
}
