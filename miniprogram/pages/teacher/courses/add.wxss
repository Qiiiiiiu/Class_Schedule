.container {
  min-height: 100vh;
  background: #e8ecf1;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: stretch;
}

/* ===== 表单区块 ===== */
.form-section {
  background: #e8ecf1;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  width: 100%;
  box-sizing: border-box;
  box-shadow: 6rpx 6rpx 14rpx #d1d6dd, -6rpx -6rpx 14rpx #ffffff;
}

.form-section.locked {
  background: #edf0f5;
  opacity: 0.8;
  box-shadow: inset 3rpx 3rpx 6rpx #d1d6dd, inset -3rpx -3rpx 6rpx #ffffff;
}

.form-section.locked .section-title {
  color: #5a6072;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1a1d28;
  display: block;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(0, 47, 167, 0.08);
}

.section-desc {
  font-size: 24rpx;
  color: #5a6072;
  margin-top: 8rpx;
  display: block;
}

.form-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 30rpx;
  width: 100%;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  width: 160rpx;
  font-size: 28rpx;
  color: #1a1d28;
  flex-shrink: 0;
  text-align: right;
  padding-right: 20rpx;
  padding-top: 16rpx;
  font-weight: 500;
}

.content-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  min-width: 0;
}

.input {
  width: 100%;
  height: 72rpx;
  background: #e8ecf1;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  box-shadow: inset 4rpx 4rpx 8rpx #d1d6dd, inset -4rpx -4rpx 8rpx #ffffff;
}

.input-disabled {
  background: #edf0f5 !important;
  color: #959dad;
  box-shadow: inset 2rpx 2rpx 4rpx #d1d6dd, inset -2rpx -2rpx 4rpx #ffffff;
}

.price-input-wrap {
  display: flex;
  align-items: center;
  width: 100%;
  height: 72rpx;
  background: #e8ecf1;
  border-radius: 16rpx;
  box-sizing: border-box;
  box-shadow: inset 4rpx 4rpx 8rpx #d1d6dd, inset -4rpx -4rpx 8rpx #ffffff;
}

.price-symbol {
  font-size: 28rpx;
  color: #5a6072;
  padding-left: 24rpx;
  padding-right: 8rpx;
}

.price-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx 0 0;
  background: transparent;
  border-radius: 0;
}

.picker-value {
  width: 100%;
  height: 72rpx;
  background: #e8ecf1;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
  box-shadow: inset 4rpx 4rpx 8rpx #d1d6dd, inset -4rpx -4rpx 8rpx #ffffff;
}

.time-picker {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.time-picker .picker-value {
  width: calc(50% - 30rpx);
  flex-shrink: 0;
}

.time-separator {
  color: #5a6072;
  font-size: 28rpx;
  width: 60rpx;
  text-align: center;
  flex-shrink: 0;
}

.switch-wrap {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.switch-label {
  font-size: 28rpx;
  color: #1a1d28;
}

/* ===== 底部操作栏 ===== */
.form-actions {
  padding: 30rpx;
}

.save-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(145deg, #001a6e, #002FA7);
  border: none;
  border-radius: 48rpx;
  font-size: 32rpx;
  color: #ffffff;
  margin-bottom: 24rpx;
  box-shadow: 6rpx 6rpx 14rpx rgba(0, 47, 167, 0.3), -3rpx -3rpx 8rpx rgba(255, 255, 255, 0.2);
}

.save-btn:active {
  box-shadow: inset 4rpx 4rpx 10rpx rgba(0, 0, 0, 0.3), inset -2rpx -2rpx 6rpx rgba(255, 255, 255, 0.05);
}

.cancel-btn {
  width: 100%;
  height: 96rpx;
  background: #e8ecf1;
  border: none;
  border-radius: 48rpx;
  font-size: 32rpx;
  color: #5a6072;
  box-shadow: 4rpx 4rpx 10rpx #d1d6dd, -4rpx -4rpx 10rpx #ffffff;
}

.cancel-btn:active {
  box-shadow: inset 4rpx 4rpx 8rpx #d1d6dd, inset -4rpx -4rpx 8rpx #ffffff;
}

/* ===== 学生列表(横向) ===== */
.student-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.student-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #edf0f5;
  border-radius: 16rpx;
  border: none;
  box-shadow: 2rpx 2rpx 4rpx #d1d6dd, -2rpx -2rpx 4rpx #ffffff;
}

.student-item.selected {
  background: #ced9f7;
  box-shadow: inset 3rpx 3rpx 6rpx rgba(0, 47, 167, 0.12), inset -2rpx -2rpx 4rpx #ffffff;
}

.student-item.disabled {
  opacity: 0.5;
  pointer-events: none;
}

.student-info {
  flex: 1;
}

.student-name {
  font-size: 28rpx;
  color: #1a1d28;
  display: block;
  margin-bottom: 8rpx;
}

.student-phone {
  font-size: 24rpx;
  color: #5a6072;
}

.student-check {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  border-radius: 50%;
  font-size: 28rpx;
  background: #e8ecf1;
  box-shadow: 2rpx 2rpx 4rpx #d1d6dd, -2rpx -2rpx 4rpx #ffffff;
}

.student-item.selected .student-check {
  background: #002FA7;
  color: #ffffff;
  box-shadow: 3rpx 3rpx 6rpx rgba(0, 47, 167, 0.3);
}

.empty-tip {
  padding: 40rpx 0;
  text-align: center;
  color: #5a6072;
  font-size: 28rpx;
}

/* ===== 星期选择器 ===== */
.weekday-picker {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  width: 100%;
  padding: 10rpx 0;
}

.weekday-item {
  width: calc((100% - 96rpx) / 7);
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e8ecf1;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #5a6072;
  border: none;
  box-shadow: 3rpx 3rpx 6rpx #d1d6dd, -3rpx -3rpx 6rpx #ffffff;
  transition: all 0.2s;
  cursor: pointer;
  touch-action: manipulation;
}

.weekday-item:active {
  transform: scale(0.95);
}

.weekday-item.selected {
  background: #002FA7;
  color: #ffffff;
  box-shadow: inset 3rpx 3rpx 6rpx rgba(0, 0, 0, 0.25), inset -2rpx -2rpx 4rpx rgba(255, 255, 255, 0.1);
}

.weekday-item.disabled {
  opacity: 0.6;
}

.switch-wrap,
.time-picker,
.price-input-wrap {
  align-self: center;
}

.picker-value,
.input,
.price-input-wrap {
  align-self: stretch;
}

.repeat-count-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.repeat-count-input {
  width: 200rpx;
  text-align: center;
}

.repeat-count-tip {
  font-size: 22rpx;
  color: #5a6072;
  margin-top: 8rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-badge {
  background: linear-gradient(145deg, #001a6e, #002FA7);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  box-shadow: 3rpx 3rpx 6rpx rgba(0, 47, 167, 0.25);
}

.badge-text {
  font-size: 22rpx;
  color: #ffffff;
}

.section-count {
  font-size: 24rpx;
  color: #5a6072;
}

.lock-tip {
  font-size: 22rpx;
  color: #dc2626;
  background: #fee2e2;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

/* ===== 子课程列表 ===== */
.child-course-list {
  margin-top: 10rpx;
}

.child-course-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #edf0f5;
  border-radius: 12rpx;
  margin-bottom: 15rpx;
  box-shadow: 2rpx 2rpx 4rpx #d1d6dd, -2rpx -2rpx 4rpx #ffffff;
}

.child-course-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.child-course-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1d28;
}

.child-course-schedule {
  font-size: 24rpx;
  color: #002FA7;
}

.child-course-room {
  font-size: 22rpx;
  color: #5a6072;
}

.child-course-price {
  font-size: 26rpx;
  color: #059669;
  font-weight: 600;
}

.student-count-badge {
  display: flex;
  align-items: baseline;
  background: #d1fae5;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
}

.count-num {
  font-size: 32rpx;
  font-weight: bold;
  color: #059669;
  margin-right: 8rpx;
}

.count-label {
  font-size: 24rpx;
  color: #059669;
}

.student-names-wrap {
  background: #d1fae5;
  padding: 12rpx 24rpx;
  border-radius: 16rpx;
  width: 100%;
  box-sizing: border-box;
}

.student-names {
  font-size: 26rpx;
  color: #059669;
  line-height: 1.5;
}

.child-course-actions {
  display: flex;
  gap: 15rpx;
  margin-left: 20rpx;
}

.action-btn {
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.edit-btn {
  background: #eef2fb;
  color: #002FA7;
  box-shadow: 2rpx 2rpx 4rpx rgba(0, 47, 167, 0.1);
}

.delete-btn {
  background: #fee2e2;
  color: #dc2626;
  box-shadow: 2rpx 2rpx 4rpx rgba(239, 68, 68, 0.1);
}

/* ===== 添加子课按钮 ===== */
.add-course-btn-wrap {
  margin-top: 20rpx;
}

.add-course-btn {
  width: 100%;
  height: 80rpx;
  font-size: 28rpx;
  border-radius: 40rpx;
}

/* ===== 弹窗 ===== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 650rpx;
  background: #e8ecf1;
  border-radius: 24rpx;
  overflow: hidden;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  box-shadow: 10rpx 10rpx 20rpx rgba(0, 0, 0, 0.15), -4rpx -4rpx 10rpx rgba(255, 255, 255, 0.3);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid rgba(0, 47, 167, 0.1);
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1d28;
}

.modal-close {
  font-size: 36rpx;
  color: #5a6072;
  padding: 10rpx;
}

.modal-body {
  flex: 1;
  padding: 30rpx;
  overflow-y: auto;
}

.modal-footer {
  padding: 20rpx 30rpx 30rpx;
  border-top: 1rpx solid rgba(0, 47, 167, 0.1);
}

.modal-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  border: none;
}

.modal-btn.confirm-btn {
  background: linear-gradient(145deg, #001a6e, #002FA7);
  color: #ffffff;
  box-shadow: 4rpx 4rpx 10rpx rgba(0, 47, 167, 0.3), -2rpx -2rpx 6rpx rgba(255, 255, 255, 0.2);
}

.modal-btn.cancel-btn {
  background: #e8ecf1;
  color: #5a6072;
  margin-top: 20rpx;
  box-shadow: 4rpx 4rpx 8rpx #d1d6dd, -4rpx -4rpx 8rpx #ffffff;
}

.generated-content {
  width: 700rpx;
}

.generated-course-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.generated-course-item {
  padding: 24rpx;
  background: #edf0f5;
  border-radius: 16rpx;
  box-shadow: 2rpx 2rpx 4rpx #d1d6dd, -2rpx -2rpx 4rpx #ffffff;
}

.generated-course-item .course-info {
  margin-bottom: 16rpx;
}

.generated-course-item .course-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #1a1d28;
  display: block;
  margin-bottom: 8rpx;
}

.generated-course-item .course-schedule {
  font-size: 26rpx;
  color: #5a6072;
}

.generated-course-item .course-detail {
  display: flex;
  gap: 30rpx;
}

.generated-course-item .course-room,
.generated-course-item .course-students {
  font-size: 24rpx;
  color: #5a6072;
}
