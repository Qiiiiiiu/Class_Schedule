page {
  width: 100%;
  overflow-x: hidden !important;
}

.page-container {
  min-height: 100vh;
  background: #0f1419;
  padding: 20rpx;
  padding-bottom: 160rpx;
  width: 100%;
  max-width: 750rpx;
  margin: 0 auto;
  box-sizing: border-box;
}

.reminder-section {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.reminder-btn {
  background: linear-gradient(145deg, #10b981, #059669);
  color: #fff;
  border: none;
  border-radius: 28rpx;
  padding: 16rpx 32rpx;
  font-size: 26rpx;
}

.info-icon {
  font-size: 32rpx;
  cursor: pointer;
}

.course-list {
  margin: 0;
  padding: 0;
}

.course-item {
  background: #23293a;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  width: 100%;
  max-width: 710rpx;
  box-sizing: border-box;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  position: relative;
}

.course-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.info-icon {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.course-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #f1f5f9;
}

.course-status {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
}

.status-available {
  background: rgba(16, 185, 129, 0.15);
  color: #10b981;
}

.status-unavailable {
  background: rgba(255, 255, 255, 0.05);
  color: #64748b;
}

.course-info {
  display: flex;
  gap: 20rpx;
  margin-bottom: 16rpx;
  flex-basis: 100%;
}

.info-item {
  font-size: 24rpx;
  color: #94a3b8;
}

.course-amount {
  display: flex;
  gap: 20rpx;
  margin-bottom: 16rpx;
  flex-basis: 100%;
}

.amount-item {
  font-size: 24rpx;
  color: #3b82f6;
}

.course-actions {
  display: flex;
  gap: 10rpx;
  width: 100%;
  box-sizing: border-box;
}

.course-actions button {
  flex: 1;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 28rpx;
  font-size: 22rpx;
  color: #94a3b8;
  padding: 0;
  margin: 0;
  width: calc(33.333% - 7rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.course-actions button::after {
  border: none;
}

.course-actions button:nth-child(2) {
  background: rgba(255, 255, 255, 0.05);
}

.course-actions button:nth-child(3) {
  color: #ef4444;
  background: rgba(239, 68, 68, 0.12);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  color: #64748b;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #64748b;
  margin-bottom: 30rpx;
}

.add-btn {
  width: 200rpx;
  height: 72rpx;
  background: linear-gradient(145deg, #3b82f6, #2563eb);
  border: none;
  border-radius: 36rpx;
  color: #ffffff;
  font-size: 26rpx;
}

.add-floating-btn {
  position: fixed;
  right: 20rpx;
  bottom: 130rpx;
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(145deg, #3b82f6, #2563eb);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.add-floating-btn text {
  font-size: 56rpx;
  color: #ffffff;
  font-weight: 300;
}
