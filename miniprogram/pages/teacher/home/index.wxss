.container {
  min-height: 100vh;
  background: #0f1419;
  padding: 30rpx;
  padding-top: 0;
  padding-bottom: 180rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 60rpx 30rpx 40rpx;
}

.welcome {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #f1f5f9;
}

.subtitle {
  font-size: 26rpx;
  color: #94a3b8;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #3b82f6, #2563eb);
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
}

/* ===== 日历 ===== */
.calendar-section {
  width: calc(100% - 60rpx);
  max-width: 680rpx;
  background: linear-gradient(145deg, #23293a, #1a1f2e);
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 0 auto 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.calendar-nav {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 50%;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.calendar-nav:active {
  box-shadow: inset 0 2rpx 6rpx rgba(0, 0, 0, 0.3);
  background: rgba(255, 255, 255, 0.04);
}

.nav-btn {
  font-size: 40rpx;
  color: #94a3b8;
  font-weight: bold;
  line-height: 1;
}

.calendar-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #f1f5f9;
}

.calendar-weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 4rpx;
  margin-bottom: 12rpx;
  padding: 0;
}

.weekday-item {
  text-align: center;
  padding: 12rpx 4rpx;
  border-radius: 8rpx;
  background: rgba(59, 130, 246, 0.1) !important;
  color: #94a3b8 !important;
  box-shadow: none !important;
  border: 1rpx solid rgba(59, 130, 246, 0.2) !important;
  box-sizing: border-box;
}

.weekday-item:first-child,
.weekday-item:last-child {
  background: rgba(239, 68, 68, 0.12) !important;
  border-color: rgba(239, 68, 68, 0.2) !important;
}

.weekday {
  font-size: 26rpx;
  font-weight: 600;
  color: #94a3b8;
}

.weekday-item:first-child .weekday,
.weekday-item:last-child .weekday {
  color: #fca5a5;
}

.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 4rpx;
}

.calendar-day {
  aspect-ratio: 1;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  box-sizing: border-box;
}

.calendar-day.has-course {
  background: rgba(59, 130, 246, 0.12);
  border-color: rgba(59, 130, 246, 0.25);
}

.day-num {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.day-num.today {
  color: rgba(0, 0, 0, 0.808);
  background: rgba(255, 255, 255, 0.9);
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
}

.day-count {
  font-size: 18rpx;
  color: inherit;
}

/* ===== 收入统计卡片 ===== */
.income-section {
  width: calc(100% - 60rpx);
  max-width: 680rpx;
  background: linear-gradient(145deg, #23293a, #1a1f2e);
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 0 auto 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.income-main {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 80rpx;
}

.income-left {
  display: flex;
  gap: 80rpx;
}

.income-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.income-label {
  font-size: 24rpx;
  color: #64748b;
}

.income-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #3b82f6;
  min-width: 200rpx;
  text-align: center;
}

.income-right {
  display: flex;
  align-items: center;
}

.eye-icon {
  width: 44rpx;
  height: 44rpx;
  color: #64748b;
  padding: 10rpx;
}

.eye-icon.active {
  color: #3b82f6;
}

.income-footer {
  padding-top: 20rpx;
  margin-top: 16rpx;
  border-top: 1rpx dashed rgba(255, 255, 255, 0.1);
  text-align: center;
}

.total-hours {
  font-size: 24rpx;
  color: #64748b;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #f1f5f9;
  display: block;
  margin-bottom: 24rpx;
}

/* ===== 快捷操作 ===== */
.quick-actions {
  width: calc(100% - 60rpx);
  max-width: 680rpx;
  margin: 50rpx auto 0;
  padding: 0;
}

.action-list {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.action-item {
  background: linear-gradient(145deg, #23293a, #1a1f2e);
  border-radius: 16rpx;
  padding: 30rpx 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.25);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.action-item:active {
  box-shadow: inset 0 4rpx 12rpx rgba(0, 0, 0, 0.4);
}

.action-icon {
  font-size: 40rpx;
  color: #3b82f6;
}

.action-text {
  font-size: 22rpx;
  color: #94a3b8;
}

/* ===== 待处理列表 ===== */
.pending-list {
  width: calc(100% - 60rpx);
  max-width: 680rpx;
  margin: 50rpx auto 0;
  padding: 0;
}

.pending-item {
  background: linear-gradient(145deg, #23293a, #1a1f2e);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.25);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.pending-item:active {
  box-shadow: inset 0 4rpx 12rpx rgba(0, 0, 0, 0.4);
}

.pending-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.pending-type {
  font-size: 24rpx;
  color: #64748b;
}

.pending-name {
  font-size: 28rpx;
  color: #f1f5f9;
  font-weight: 500;
}

.pending-arrow {
  font-size: 40rpx;
  color: #64748b;
}
