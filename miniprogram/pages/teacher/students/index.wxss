.container {
  min-height: 100vh;
  background: #0f1419;
  padding: 30rpx;
  padding-bottom: 180rpx;
}

.stats-header {
  background: linear-gradient(145deg, #23293a, #1a1f2e);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.action-btns {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.add-btn {
  background: rgba(59, 130, 246, 0.15);
  color: #3b82f6;
  border: 1rpx solid rgba(59, 130, 246, 0.2);
  border-radius: 30rpx;
  padding: 16rpx 32rpx;
  font-size: 26rpx;
}

.add-btn.secondary {
  background: rgba(255, 255, 255, 0.05);
  color: #94a3b8;
  border-color: rgba(255, 255, 255, 0.1);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.stat-num {
  font-size: 60rpx;
  font-weight: bold;
  color: #f1f5f9;
}

.stat-label {
  font-size: 26rpx;
  color: #94a3b8;
}

/* ===== 验证码区 ===== */
.verify-code-section {
  background: linear-gradient(145deg, #23293a, #1a1f2e);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.code-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.code-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #f1f5f9;
}

.code-expire {
  font-size: 24rpx;
  color: #64748b;
}

.code-display {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 0;
}

.code-value {
  font-size: 60rpx;
  font-weight: bold;
  color: #3b82f6;
  letter-spacing: 8rpx;
  margin-bottom: 16rpx;
}

.code-hint {
  font-size: 24rpx;
  color: #64748b;
}

/* ===== 搜索 ===== */
.filter-bar {
  margin-bottom: 30rpx;
}

.search-box {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 50rpx;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #f1f5f9;
}

.search-icon {
  font-size: 28rpx;
  color: #64748b;
  padding: 10rpx;
}

/* ===== 学生列表 ===== */
.student-list {
  background: linear-gradient(145deg, #23293a, #1a1f2e);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.student-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.student-item:active {
  background: rgba(255, 255, 255, 0.03);
}

.student-item:last-child {
  border-bottom: none;
}

.student-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.student-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #3b82f6, #2563eb);
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.3);
}

.info-text {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.student-name {
  font-size: 30rpx;
  color: #f1f5f9;
  font-weight: 500;
}

.student-meta {
  font-size: 24rpx;
  color: #64748b;
}

/* ===== 状态标签 ===== */
.student-status {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.status-approved {
  background: rgba(16, 185, 129, 0.15);
  color: #10b981;
}

.status-pending {
  background: rgba(245, 158, 11, 0.15);
  color: #f59e0b;
}

.status-rejected {
  background: rgba(239, 68, 68, 0.15);
  color: #ef4444;
}

.status-unbound {
  background: rgba(255, 255, 255, 0.05);
  color: #64748b;
}

.student-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
}

.bind-btn {
  background: linear-gradient(145deg, #3b82f6, #2563eb);
  color: #ffffff;
  border: none;
  border-radius: 20rpx;
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(59, 130, 246, 0.3);
}

.merge-btn {
  background: linear-gradient(145deg, #f59e0b, #d97706);
  color: #ffffff;
  border: none;
  border-radius: 20rpx;
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(245, 158, 11, 0.3);
}

.delete-btn {
  background: rgba(239, 68, 68, 0.15);
  color: #ef4444;
  border: 1rpx solid rgba(239, 68, 68, 0.2);
  border-radius: 20rpx;
  padding: 8rpx 20rpx;
  font-size: 24rpx;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  color: #64748b;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #64748b;
}

/* ===== 弹窗 ===== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 680rpx;
  background: linear-gradient(145deg, #23293a, #1a1f2e);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.4);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.modal-content.detail-content {
  max-height: 80vh;
  overflow-y: auto;
}

.modal-content.add-content {
  max-height: 80vh;
  overflow-y: auto;
}

.modal-content.merge-content {
  max-height: 80vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #f1f5f9;
}

.modal-close {
  font-size: 36rpx;
  color: #64748b;
  padding: 10rpx;
}

.modal-body {
  padding: 30rpx;
  max-height: 50vh;
  overflow-y: auto;
}

/* ===== 合并信息 ===== */
.merge-info {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: rgba(245, 158, 11, 0.15);
  border-radius: 10rpx;
  margin-bottom: 30rpx;
}

.merge-label {
  font-size: 26rpx;
  color: #f59e0b;
  margin-right: 12rpx;
}

.merge-value {
  font-size: 28rpx;
  color: #f1f5f9;
  font-weight: 500;
}

/* ===== 表单 ===== */
.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #94a3b8;
  margin-bottom: 16rpx;
  display: block;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 32rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #f1f5f9;
  line-height: 88rpx;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  padding: 28rpx 32rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #f1f5f9;
  min-height: 120rpx;
  box-sizing: border-box;
}

.target-student-list {
  max-height: 400rpx;
  overflow-y: auto;
}

.target-student-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  transition: all 0.2s;
}

.target-student-item:last-child {
  margin-bottom: 0;
}

.target-student-item.selected {
  background: rgba(59, 130, 246, 0.15);
  border-color: rgba(59, 130, 246, 0.3);
}

.target-avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #3b82f6, #2563eb);
  margin-right: 20rpx;
}

.target-name {
  flex: 1;
  font-size: 28rpx;
  color: #f1f5f9;
}

.check-icon {
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(145deg, #3b82f6, #2563eb);
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(59, 130, 246, 0.4);
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.modal-btn {
  flex: 1;
  padding: 24rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.cancel-btn {
  background: rgba(255, 255, 255, 0.05);
  color: #94a3b8;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.confirm-btn {
  background: linear-gradient(145deg, #3b82f6, #2563eb);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.4);
}

.confirm-btn[disabled] {
  background: #334155;
  color: #64748b;
  box-shadow: none;
}
