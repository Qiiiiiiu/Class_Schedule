.container {
  min-height: 100vh;
  background: #e8ecf1;
  padding: 30rpx;
}

.stats-header {
  background: linear-gradient(145deg, #001a6e, #1e4dc8);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 6rpx 6rpx 14rpx rgba(0, 47, 167, 0.18), -4rpx -4rpx 10rpx rgba(255, 255, 255, 0.5);
}

.action-btns {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.add-btn {
  background: rgba(255, 255, 255, 0.15);
  color: #ffffff;
  border: none;
  border-radius: 30rpx;
  padding: 16rpx 32rpx;
  font-size: 26rpx;
  box-shadow: 3rpx 3rpx 6rpx rgba(0, 0, 0, 0.12), -2rpx -2rpx 4rpx rgba(255, 255, 255, 0.08);
}

.add-btn.secondary {
  background: rgba(255, 255, 255, 0.1);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.stat-num {
  font-size: 60rpx;
  font-weight: bold;
  color: #ffffff;
}

.stat-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* ===== 验证码区 ===== */
.verify-code-section {
  background: #e8ecf1;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 6rpx 6rpx 14rpx #d1d6dd, -6rpx -6rpx 14rpx #ffffff;
}

.code-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.code-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1d28;
}

.code-expire {
  font-size: 24rpx;
  color: #5a6072;
}

.code-display {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 0;
}

.code-value {
  font-size: 60rpx;
  font-weight: bold;
  color: #002FA7;
  letter-spacing: 8rpx;
  margin-bottom: 16rpx;
}

.code-hint {
  font-size: 24rpx;
  color: #5a6072;
}

/* ===== 搜索 ===== */
.filter-bar {
  margin-bottom: 30rpx;
}

.search-box {
  background: #e8ecf1;
  border-radius: 50rpx;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: inset 4rpx 4rpx 8rpx #d1d6dd, inset -4rpx -4rpx 8rpx #ffffff;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.search-icon {
  font-size: 28rpx;
  color: #5a6072;
  padding: 10rpx;
}

/* ===== 学生列表 ===== */
.student-list {
  background: #e8ecf1;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 6rpx 6rpx 14rpx #d1d6dd, -6rpx -6rpx 14rpx #ffffff;
}

.student-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid rgba(0, 47, 167, 0.08);
}

.student-item:active {
  background: #eef2fb;
}

.student-item:last-child {
  border-bottom: none;
}

.student-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.student-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #ced9f7, #eef2fb);
  box-shadow: 3rpx 3rpx 6rpx #d1d6dd, -3rpx -3rpx 6rpx #ffffff;
}

.info-text {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.student-name {
  font-size: 30rpx;
  color: #1a1d28;
  font-weight: 500;
}

.student-meta {
  font-size: 24rpx;
  color: #5a6072;
}

/* ===== 状态标签 ===== */
.student-status {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.status-approved {
  background: #d1fae5;
  color: #059669;
}

.status-pending {
  background: #fef3c7;
  color: #d97706;
}

.status-rejected {
  background: #fee2e2;
  color: #dc2626;
}

.status-unbound {
  background: #e8ecf1;
  color: #5a6072;
  box-shadow: inset 2rpx 2rpx 4rpx #d1d6dd, inset -2rpx -2rpx 4rpx #ffffff;
}

.student-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
}

.bind-btn {
  background: linear-gradient(145deg, #001a6e, #002FA7);
  color: #ffffff;
  border: none;
  border-radius: 20rpx;
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  box-shadow: 3rpx 3rpx 6rpx rgba(0, 47, 167, 0.2), -2rpx -2rpx 4rpx rgba(255, 255, 255, 0.5);
}

.merge-btn {
  background: linear-gradient(145deg, #b45309, #d97706);
  color: #ffffff;
  border: none;
  border-radius: 20rpx;
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  box-shadow: 3rpx 3rpx 6rpx rgba(180, 83, 9, 0.25);
}

.delete-btn {
  background: #fee2e2;
  color: #dc2626;
  border: none;
  border-radius: 20rpx;
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  box-shadow: 2rpx 2rpx 4rpx rgba(239, 68, 68, 0.12);
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #5a6072;
}

/* ===== 弹窗 ===== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 680rpx;
  background: #e8ecf1;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 10rpx 10rpx 20rpx rgba(0, 0, 0, 0.15), -4rpx -4rpx 10rpx rgba(255, 255, 255, 0.3);
}

.modal-content.detail-content {
  max-height: 80vh;
  overflow-y: auto;
}

.modal-content.add-content {
  max-height: 80vh;
  overflow-y: auto;
}

.modal-content.merge-content {
  max-height: 80vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid rgba(0, 47, 167, 0.1);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1d28;
}

.modal-close {
  font-size: 36rpx;
  color: #5a6072;
  padding: 10rpx;
}

.modal-body {
  padding: 30rpx;
  max-height: 50vh;
  overflow-y: auto;
}

/* ===== 合并信息 ===== */
.merge-info {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #fef3c7;
  border-radius: 10rpx;
  margin-bottom: 30rpx;
}

.merge-label {
  font-size: 26rpx;
  color: #d97706;
  margin-right: 12rpx;
}

.merge-value {
  font-size: 28rpx;
  color: #1a1d28;
  font-weight: 500;
}

/* ===== 表单 ===== */
.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #1a1d28;
  margin-bottom: 16rpx;
  display: block;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 32rpx;
  background: #e8ecf1;
  border-radius: 10rpx;
  font-size: 28rpx;
  line-height: 88rpx;
  box-sizing: border-box;
  box-shadow: inset 4rpx 4rpx 8rpx #d1d6dd, inset -4rpx -4rpx 8rpx #ffffff;
}

.form-textarea {
  width: 100%;
  padding: 28rpx 32rpx;
  background: #e8ecf1;
  border-radius: 10rpx;
  font-size: 28rpx;
  min-height: 120rpx;
  box-sizing: border-box;
  box-shadow: inset 4rpx 4rpx 8rpx #d1d6dd, inset -4rpx -4rpx 8rpx #ffffff;
}

.target-student-list {
  max-height: 400rpx;
  overflow-y: auto;
}

.target-student-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #edf0f5;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  transition: all 0.2s;
  box-shadow: 2rpx 2rpx 4rpx #d1d6dd, -2rpx -2rpx 4rpx #ffffff;
}

.target-student-item:last-child {
  margin-bottom: 0;
}

.target-student-item.selected {
  background: #ced9f7;
  box-shadow: inset 3rpx 3rpx 6rpx rgba(0, 47, 167, 0.12), inset -2rpx -2rpx 4rpx #ffffff;
}

.target-avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #ced9f7, #eef2fb);
  margin-right: 20rpx;
}

.target-name {
  flex: 1;
  font-size: 28rpx;
  color: #1a1d28;
}

.check-icon {
  width: 40rpx;
  height: 40rpx;
  background: #002FA7;
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  box-shadow: 3rpx 3rpx 6rpx rgba(0, 47, 167, 0.25);
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 1rpx solid rgba(0, 47, 167, 0.1);
}

.modal-btn {
  flex: 1;
  padding: 24rpx 0;
  border-radius: 10rpx;
  font-size: 28rpx;
}

.cancel-btn {
  background: #e8ecf1;
  color: #5a6072;
  box-shadow: 4rpx 4rpx 8rpx #d1d6dd, -4rpx -4rpx 8rpx #ffffff;
}

.confirm-btn {
  background: linear-gradient(145deg, #001a6e, #002FA7);
  color: #ffffff;
  box-shadow: 4rpx 4rpx 8rpx rgba(0, 47, 167, 0.25), -2rpx -2rpx 4rpx rgba(255, 255, 255, 0.4);
}

.confirm-btn[disabled] {
  background: #cbd5e0;
  color: #959dad;
  box-shadow: none;
}
