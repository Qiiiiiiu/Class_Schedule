.container {
  min-height: 100vh;
  background: #e8ecf1;
}

/* ===== Tab ===== */
.tabs {
  background: #e8ecf1;
  display: flex;
  padding: 0 30rpx;
  border-bottom: 1rpx solid rgba(0, 47, 167, 0.08);
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.04);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #5a6072;
  position: relative;
}

.tab-item.active {
  color: #002FA7;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: #002FA7;
  border-radius: 3rpx;
}

.badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  background: #ef4444;
  color: #ffffff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  min-width: 32rpx;
  text-align: center;
}

/* ===== 绑定列表 ===== */
.binding-list {
  padding: 30rpx;
}

.binding-item {
  background: #e8ecf1;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 6rpx 6rpx 14rpx #d1d6dd, -6rpx -6rpx 14rpx #ffffff;
}

.binding-info {
  display: flex;
  gap: 20rpx;
  flex: 1;
}

.student-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #ced9f7, #eef2fb);
  flex-shrink: 0;
  box-shadow: 3rpx 3rpx 6rpx #d1d6dd, -3rpx -3rpx 6rpx #ffffff;
}

.info-text {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.student-name {
  font-size: 30rpx;
  color: #1a1d28;
  font-weight: 500;
}

.apply-time {
  font-size: 24rpx;
  color: #5a6072;
}

.remark {
  font-size: 24rpx;
  color: #5a6072;
  margin-top: 4rpx;
}

.binding-actions {
  display: flex;
  gap: 16rpx;
}

.approve-btn,
.reject-btn {
  width: 120rpx;
  height: 60rpx;
  border: none;
  border-radius: 30rpx;
  font-size: 24rpx;
}

.approve-btn {
  background: linear-gradient(145deg, #001a6e, #002FA7);
  color: #ffffff;
  box-shadow: 3rpx 3rpx 6rpx rgba(0, 47, 167, 0.25);
}

.reject-btn {
  background: #fee2e2;
  color: #dc2626;
  box-shadow: 2rpx 2rpx 4rpx rgba(239, 68, 68, 0.12);
}

.binding-status {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.status-approved {
  background: #d1fae5;
  color: #059669;
}

.status-rejected {
  background: #fee2e2;
  color: #dc2626;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #5a6072;
}
