.container {
  min-height: 100vh;
  background: #e8ecf1;
  padding-bottom: 30rpx;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}

/* ===== 周导航 ===== */
.week-nav {
  background: #e8ecf1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 30rpx;
  gap: 30rpx;
  width: 100%;
  box-sizing: border-box;
  box-shadow: 3rpx 3rpx 6rpx #d1d6dd, -3rpx -3rpx 6rpx #ffffff;
}

.nav-arrow {
  font-size: 48rpx;
  color: #002FA7;
  padding: 10rpx 20rpx;
}

.week-label {
  font-size: 30rpx;
  font-weight: bold;
  color: #1a1d28;
}

/* ===== 课程表格 ===== */
.schedule-grid {
  display: flex;
  background: #e8ecf1;
  overflow-x: hidden;
  padding-bottom: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.time-column {
  width: 100rpx;
  flex-shrink: 0;
}

.time-header {
  height: 100rpx;
  border-bottom: 1rpx solid rgba(0, 47, 167, 0.08);
}

.time-slot {
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #5a6072;
  border-bottom: 1rpx solid rgba(0, 47, 167, 0.06);
}

.day-column {
  width: calc((100% - 100rpx) / 7);
  flex-shrink: 0;
  border-left: 1rpx solid rgba(0, 47, 167, 0.06);
}

.day-header {
  height: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-bottom: 1rpx solid rgba(0, 47, 167, 0.08);
}

.day-header.today {
  background: #ced9f7;
  box-shadow: inset 2rpx 2rpx 4rpx rgba(0, 47, 167, 0.08), inset -2rpx -2rpx 4rpx #ffffff;
}

.day-name {
  font-size: 28rpx;
  color: #1a1d28;
  font-weight: 500;
}

.day-date {
  font-size: 24rpx;
  color: #5a6072;
  margin-top: 4rpx;
}

.day-header.today .day-name {
  color: #002FA7;
}

.day-slots {
  position: relative;
  height: calc(120rpx * 18);
}

.schedule-item {
  position: absolute;
  left: 4rpx;
  right: 4rpx;
  border-radius: 8rpx;
  padding: 10rpx;
  box-sizing: border-box;
  overflow: hidden;
  box-shadow: 2rpx 2rpx 4rpx rgba(0, 47, 167, 0.12);
}

.schedule-item.unavailable {
  background: #cbd5e0;
  box-shadow: inset 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.1), inset -1rpx -1rpx 2rpx rgba(255, 255, 255, 0.3);
}

.course-name {
  display: block;
  font-size: 22rpx;
  font-weight: bold;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  color: #ffffff;
}

.course-time {
  display: block;
  font-size: 18rpx;
  margin-top: 4rpx;
  opacity: 0.85;
  color: #ffffff;
}

.course-room {
  display: block;
  font-size: 18rpx;
  margin-top: 2rpx;
  opacity: 0.7;
  color: #ffffff;
}

.schedule-item.unavailable .course-name,
.schedule-item.unavailable .course-time,
.schedule-item.unavailable .course-room {
  color: #5a6072;
}

/* ===== 底部弹窗详情 ===== */
.course-detail {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 100;
}

.detail-card {
  width: 100%;
  background: #e8ecf1;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx;
  box-sizing: border-box;
  box-shadow: 0 -8rpx 20rpx rgba(0, 0, 0, 0.1);
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.detail-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a1d28;
}

.detail-close {
  font-size: 40rpx;
  color: #5a6072;
  padding: 10rpx;
}

.detail-info {
  margin-bottom: 30rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(0, 47, 167, 0.06);
}

.detail-label {
  font-size: 28rpx;
  color: #5a6072;
}

.detail-value {
  font-size: 28rpx;
  color: #1a1d28;
}

.detail-value.status-available {
  color: #059669;
}

.detail-value.status-unavailable {
  color: #5a6072;
}

.detail-actions {
  display: flex;
  gap: 20rpx;
}

.detail-btn {
  flex: 1;
  height: 80rpx;
  background: #e8ecf1;
  border: none;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #1a1d28;
  box-shadow: 4rpx 4rpx 8rpx #d1d6dd, -4rpx -4rpx 8rpx #ffffff;
}

.detail-btn:active {
  box-shadow: inset 4rpx 4rpx 8rpx #d1d6dd, inset -4rpx -4rpx 8rpx #ffffff;
}

.detail-btn:first-child {
  background: linear-gradient(145deg, #001a6e, #002FA7);
  color: #ffffff;
  box-shadow: 4rpx 4rpx 10rpx rgba(0, 47, 167, 0.3), -2rpx -2rpx 6rpx rgba(255, 255, 255, 0.2);
}

.detail-btn:first-child:active {
  box-shadow: inset 4rpx 4rpx 10rpx rgba(0, 0, 0, 0.3), inset -2rpx -2rpx 6rpx rgba(255, 255, 255, 0.05);
}
