.container {
  min-height: 100vh;
  background: #0f1419;
  padding-bottom: 180rpx;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}

/* ===== 周导航 ===== */
.week-nav {
  background: #1a1f2e;
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  width: 100%;
  box-sizing: border-box;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.week-nav-center {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 30rpx;
}

.nav-arrow {
  font-size: 48rpx;
  color: #3b82f6;
  padding: 10rpx 20rpx;
}

.week-label {
  font-size: 30rpx;
  font-weight: bold;
  color: #f1f5f9;
}

/* ===== 筛选图标 ===== */
.filter-icon {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 50%;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  /* margin-left: 20rpx; */
}

/* ===== 筛选弹窗 ===== */
.filter-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.filter-modal-content {
  width: 85%;
  max-width: 600rpx;
  height: 560rpx;
  background: linear-gradient(145deg, #23293a, #1a1f2e);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.4);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  display: flex;
  flex-direction: column;
}

.filter-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.filter-modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #f1f5f9;
}

.filter-modal-close {
  font-size: 36rpx;
  color: #64748b;
  padding: 10rpx;
}

.filter-modal-body {
  flex: 1;
  padding: 20rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.filter-search-wrap {
  margin-bottom: 20rpx;
}

.filter-search-input {
  width: 100%;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  color: #f1f5f9;
  box-sizing: border-box;
}

.search-placeholder {
  color: #64748b;
}

.filter-student-list {
  flex: 1;
  overflow-y: auto;
}

.filter-student-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 20rpx;
  border-radius: 12rpx;
  margin-bottom: 8rpx;
  background: rgba(255, 255, 255, 0.03);
}

.filter-student-item.selected {
  background: rgba(59, 130, 246, 0.15);
  border: 1rpx solid rgba(59, 130, 246, 0.3);
}

.filter-student-name {
  font-size: 28rpx;
  color: #f1f5f9;
}

.filter-student-check {
  width: 40rpx;
  height: 40rpx;
  background: #3b82f6;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 24rpx;
}

.filter-empty {
  text-align: center;
  padding: 40rpx;
  color: #64748b;
  font-size: 28rpx;
}

/* ===== 课程表格 ===== */
.schedule-grid {
  display: flex;
  background: #0f1419;
  overflow-x: hidden;
  padding-bottom: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.time-column {
  width: 100rpx;
  flex-shrink: 0;
}

.time-header {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.time-slot {
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #64748b;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.04);
}

.day-column {
  width: calc((100% - 100rpx) / 7);
  flex-shrink: 0;
  border-left: 1rpx solid rgba(255, 255, 255, 0.04);
}

.day-header {
  height: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
  background: #1a1f2e;
}

.day-header.today {
  background: rgba(59, 130, 246, 0.15);
  box-shadow: inset 0 0 20rpx rgba(59, 130, 246, 0.1);
}

.day-name {
  font-size: 28rpx;
  color: #94a3b8;
  font-weight: 500;
}

.day-date {
  font-size: 24rpx;
  color: #64748b;
  margin-top: 4rpx;
}

.day-header.today .day-name {
  color: #3b82f6;
}

.day-header.today .day-date {
  color: #f1f5f9;
}

.day-slots {
  position: relative;
  height: calc(120rpx * 18);
  background: rgba(255, 255, 255, 0.02);
}

.schedule-item {
  position: absolute;
  left: 4rpx;
  right: 4rpx;
  border-radius: 8rpx;
  padding: 10rpx;
  box-sizing: border-box;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}

.schedule-item.unavailable {
  background: rgba(255, 255, 255, 0.03);
  box-shadow: inset 0 0 10rpx rgba(0, 0, 0, 0.3);
}

.course-name {
  display: block;
  font-size: 22rpx;
  font-weight: bold;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  color: #ffffff;
}

.course-time {
  display: block;
  font-size: 18rpx;
  margin-top: 4rpx;
  opacity: 0.85;
  color: #ffffff;
}

.course-room {
  display: block;
  font-size: 18rpx;
  margin-top: 2rpx;
  opacity: 0.7;
  color: #ffffff;
}

.schedule-item.unavailable .course-name,
.schedule-item.unavailable .course-time,
.schedule-item.unavailable .course-room {
  color: #64748b;
}

/* ===== 底部弹窗详情 ===== */
.course-detail {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 100;
}

.detail-card {
  width: 100%;
  background: linear-gradient(145deg, #23293a, #1a1f2e);
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx;
  box-sizing: border-box;
  box-shadow: 0 -8rpx 30rpx rgba(0, 0, 0, 0.4);
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.detail-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #f1f5f9;
}

.detail-close {
  font-size: 40rpx;
  color: #64748b;
  padding: 10rpx;
}

.detail-info {
  margin-bottom: 30rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.detail-label {
  font-size: 28rpx;
  color: #64748b;
}

.detail-value {
  font-size: 28rpx;
  color: #f1f5f9;
}

.detail-value.status-available {
  color: #10b981;
}

.detail-value.status-unavailable {
  color: #64748b;
}

.detail-actions {
  display: flex;
  gap: 20rpx;
}

.detail-btn {
  flex: 1;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #94a3b8;
}

.detail-btn:active {
  background: rgba(255, 255, 255, 0.08);
}

.detail-btn:first-child {
  background: linear-gradient(145deg, #3b82f6, #2563eb);
  color: #ffffff;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.3);
}

.detail-btn:first-child:active {
  box-shadow: inset 0 4rpx 8rpx rgba(0, 0, 0, 0.3);
}

.detail-btn.delete {
  background: rgba(239, 68, 68, 0.15);
  color: #ef4444;
  border: 1rpx solid rgba(239, 68, 68, 0.3);
}

.detail-btn.delete:active {
  background: rgba(239, 68, 68, 0.25);
}

/* ===== 编辑模式样式 ===== */
.edit-section {
  margin-bottom: 30rpx;
}

.edit-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.edit-label {
  font-size: 28rpx;
  color: #64748b;
}

.edit-picker {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #f1f5f9;
  min-width: 200rpx;
  justify-content: space-between;
}

.picker-arrow {
  font-size: 22rpx;
  color: #64748b;
}

.edit-input {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #f1f5f9;
  padding: 12rpx 0;
  margin-left: 20rpx;
}

.edit-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.edit-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.edit-btn.cancel {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  color: #94a3b8;
}

.edit-btn.save {
  background: linear-gradient(145deg, #10b981, #059669);
  color: #ffffff;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.3);
}

.edit-btn:active {
  opacity: 0.85;
}
