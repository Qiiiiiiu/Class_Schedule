/* example page — 克莱因蓝 + 轻拟态 */

page {
  background-color: #e8ecf1;
  padding-bottom: 50px;
  font-family: PingFang SC;
}

.page-container {
  padding: 20rpx 40rpx;
}

.tip {
  font-size: 23rpx;
  color: #5a6072;
  width: 90%;
  text-align: center;
  margin: 30rpx auto 0 auto;
}

.top_tip {
  font-size: 28rpx;
  color: #5a6072;
  width: 90%;
  text-align: left;
  margin-top: 30rpx;
}

.box_text {
  background-color: #e8ecf1;
  text-align: center;
  padding: 300rpx 0;
  margin-top: 30rpx;
  color: #5a6072;
  border-radius: 16rpx;
  box-shadow: 4rpx 4rpx 10rpx #d1d6dd, -4rpx -4rpx 10rpx #ffffff;
}

.button {
  width: 300rpx;
  text-align: center;
  margin: 250rpx auto 0 auto;
  height: 80rpx;
  color: #ffffff;
  border-radius: 40rpx;
  line-height: 80rpx;
  background: linear-gradient(145deg, #001a6e, #002FA7);
  box-shadow: 4rpx 4rpx 10rpx rgba(0, 47, 167, 0.3), -2rpx -2rpx 6rpx rgba(255, 255, 255, 0.2);
}

.button_clear {
  width: 300rpx;
  text-align: center;
  margin: 0 auto 0 auto;
  height: 80rpx;
  color: #002FA7;
  border-radius: 40rpx;
  line-height: 80rpx;
  background: #e8ecf1;
  box-shadow: 4rpx 4rpx 8rpx #d1d6dd, -4rpx -4rpx 8rpx #ffffff;
}

.line {
  height: 1rpx;
  width: 100%;
  background-color: rgba(0, 47, 167, 0.08);
}

.code_box {
  text-align: center;
  background: #e8ecf1;
  margin-top: 30rpx;
  padding: 17rpx;
  border-radius: 16rpx;
  box-shadow: 4rpx 4rpx 10rpx #d1d6dd, -4rpx -4rpx 10rpx #ffffff;
}

.code_box_title {
  color: #5a6072;
  font-size: 26rpx;
  margin-bottom: 20rpx;
  text-align: left;
}

.code_box_record {
  display: flex;
}

.code_box_record_title {
  width: 33%;
  font-size: 26rpx;
  color: #5a6072;
  padding: 20rpx 0;
}

.code_box_record_detail {
  width: 25%;
  font-size: 26rpx;
  padding: 20rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.title {
  margin-top: 16px;
  margin-bottom: 8px;
  font-size: 36rpx;
  font-weight: 500;
  color: #1a1d28;
}

.info {
  margin-top: 12px;
  font-size: 28rpx;
  font-weight: 400;
  color: #5a6072;
  line-height: 52rpx;
}

.img {
  width: 100%;
}

.step-img {
  margin-top: 20rpx;
  border-radius: 12rpx;
  box-shadow: 4rpx 4rpx 10rpx #d1d6dd, -4rpx -4rpx 10rpx #ffffff;
}

.code_img {
  width: 360rpx;
  height: 360rpx;
}

.block {
  font-size: 16px;
  line-height: 40px;
}

.step-left {
  color: #ffffff;
  background-color: #002FA7;
  border: #002FA7 solid 1px;
  padding: 0px 6px;
}

.step-right {
  color: #002FA7;
  background-color: #ffffff;
  border: #002FA7 solid 1px;
  padding: 0px 6px;
  margin-right: 10px;
}

.code_zone {
  background-color: #0E190E;
  color: rgba(255, 255, 255, 0.7);
  border-radius: 12rpx;
  padding: 16rpx 32rpx;
  box-shadow: 0 6px 8px rgba(0, 0, 0, 0.15);
  position: relative;
  margin-bottom: 24rpx;
}

.btn-full {
  height: 40px;
  border-radius: 20rpx;
  line-height: 40px;
  color: #ffffff;
  background: linear-gradient(145deg, #001a6e, #002FA7);
  text-align: center;
  margin-bottom: 5px;
}

.step-title {
  line-height: 37px;
  font-size: 16px;
}

.step-text {
  font-size: 14px;
  line-height: 24px;
  padding: 10px 0px;
  text-align: justify;
}

.modal-mask {
  position: fixed; left: 0; top: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.3); z-index: 1000; display: flex; align-items: center; justify-content: center;
}

.modal-content {
  background: #e8ecf1; padding: 24px; border-radius: 16rpx; width: 80%;
  box-shadow: 8rpx 8rpx 20rpx rgba(0, 0, 0, 0.15), -4rpx -4rpx 10rpx rgba(255, 255, 255, 0.2);
}

.modal-title { font-size: 18px; margin-bottom: 16px; }

.modal-input { margin-bottom: 12px; border: none; padding: 8px; border-radius: 8rpx; width: 100%; background: #e8ecf1; box-shadow: inset 3rpx 3rpx 6rpx #d1d6dd, inset -3rpx -3rpx 6rpx #ffffff; }

.modal-actions { display: flex; justify-content: flex-end; gap: 12px; }

/* AI助手相关样式 */
.notice-box {
  background: #fef3c7;
  border-left: 4rpx solid #d97706;
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  margin: 20rpx 0;
  box-shadow: 2rpx 2rpx 4rpx rgba(217, 119, 6, 0.08);
}

.notice-text {
  font-size: 26rpx;
  color: #1a1d28;
  line-height: 40rpx;
}

.notice-highlight {
  color: #d97706;
  font-weight: 600;
}

.shortcut-box {
  background: #e8ecf1;
  border-radius: 12rpx;
  padding: 24rpx;
  margin: 20rpx 0;
  box-shadow: 3rpx 3rpx 6rpx #d1d6dd, -3rpx -3rpx 6rpx #ffffff;
}

.shortcut-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.shortcut-item:last-child {
  margin-bottom: 0;
}

.shortcut-label {
  font-size: 28rpx;
  color: #5a6072;
  width: 240rpx;
  flex-shrink: 0;
}

.shortcut-key {
  font-size: 28rpx;
  color: #002FA7;
  font-weight: 500;
  background-color: #eef2fb;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  white-space: nowrap;
}

.plugin-name-box {
  background-color: #eef2fb;
  border-left: 4rpx solid #002FA7;
  padding: 20rpx;
  margin: 20rpx 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-radius: 8rpx;
}

.plugin-name {
  font-size: 32rpx;
  color: #002FA7;
  font-weight: 500;
  flex: 1;
}

.copy-btn {
  display: flex;
  align-items: center;
  padding: 6rpx 16rpx;
  background-color: #eef2fb;
  border: 1rpx solid #ced9f7;
  border-radius: 8rpx;
  margin-left: 20rpx;
  transition: all 0.2s;
}

.copy-btn:active {
  background-color: #ced9f7;
}

.copy-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 6rpx;
}

.copy-text {
  font-size: 24rpx;
  color: #002FA7;
  font-weight: 500;
}

.divider {
  height: 1rpx;
  width: 100%;
  background-color: rgba(0, 47, 167, 0.08);
  margin: 40rpx 0;
}

.feature-section {
  margin-top: 20rpx;
}

.feature-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #1a1d28;
  margin-bottom: 20rpx;
}

.feature-list {
  padding-left: 0;
}

.feature-item {
  font-size: 28rpx;
  color: #5a6072;
  line-height: 48rpx;
  margin-bottom: 12rpx;
}

.feature-item-with-examples {
  margin-bottom: 20rpx;
  padding: 20rpx;
  background: #e8ecf1;
  border-radius: 12rpx;
  box-shadow: 3rpx 3rpx 6rpx #d1d6dd, -3rpx -3rpx 6rpx #ffffff;
}

.feature-item-with-examples:last-child {
  margin-bottom: 0;
}

.feature-main {
  font-size: 30rpx;
  font-weight: 500;
  color: #1a1d28;
  margin-bottom: 12rpx;
  padding-bottom: 8rpx;
  border-bottom: 1rpx solid rgba(0, 47, 167, 0.08);
}

.feature-examples {
  padding-left: 0;
}

.feature-example {
  font-size: 26rpx;
  color: #5a6072;
  line-height: 44rpx;
  margin-bottom: 8rpx;
}

.feature-example-wrapper {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 4rpx;
  padding: 8rpx 12rpx;
}

.feature-example-text {
  flex: 1;
  font-size: 26rpx;
  color: #5a6072;
  line-height: 40rpx;
}

.feature-copy-btn {
  padding: 12rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 12rpx;
  flex-shrink: 0;
  transition: all 0.2s;
}

.feature-copy-btn:active {
  background-color: #ced9f7;
}

.feature-copy-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.5;
  transition: opacity 0.2s;
}

.feature-copy-btn:active .feature-copy-icon {
  opacity: 0.8;
}
