<view class="container">
  <view class="header">
    <image class="logo" src="/images/icons/avatar.png" mode="aspectFit"></image>
    <text class="title">课程管理小程序</text>
    <text class="subtitle">教师端 & 学生端</text>
  </view>



  <view class="login-form" wx:if="{{showLoginForm}}">
    <!-- 错误提示 -->
    <view class="error-message" wx:if="{{loginError}}">
      <text class="error-icon">⚠️</text>
      <text class="error-text">{{loginError}}</text>
      <button class="retry-btn" bindtap="retryLogin">重新尝试</button>
    </view>

    <view class="form-item">
      <text class="label">姓名</text>
      <input class="input" placeholder="请输入您的姓名" value="{{name}}" bindinput="onNameInput" />
    </view>

    <view class="form-item">
      <text class="label">角色</text>
      <radio-group class="role-group" bindchange="onRoleChange">
        <label class="role-item">
          <radio value="teacher" checked="{{role === 'teacher'}}" color="#002FA7" />
          <text class="role-text">教师</text>
        </label>
        <label class="role-item">
          <radio value="student" checked="{{role === 'student'}}" color="#002FA7" />
          <text class="role-text">学生</text>
        </label>
      </radio-group>
    </view>

    <button class="login-btn" type="primary" bindtap="onLogin" loading="{{loading}}">
      登录
    </button>
  </view>

  <view class="loading-container" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">正在登录...</text>
  </view>

</view>