.container {
  min-height: 100vh;
  background: linear-gradient(160deg, #0f1419 0%, #1a1f2e 50%, #0f1419 100%);
  padding: 60rpx 40rpx;
  box-sizing: border-box;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
  padding-top: 60rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #3b82f6, #2563eb);
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #f1f5f9;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #64748b;
}

.login-form {
  background: linear-gradient(145deg, #23293a, #1a1f2e);
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.4), inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.form-item {
  margin-bottom: 40rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #94a3b8;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.input {
  width: 100%;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 0 30rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  color: #f1f5f9;
}

.role-group {
  display: flex;
  gap: 60rpx;
}

.role-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.role-text {
  font-size: 30rpx;
  color: #94a3b8;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(145deg, #3b82f6, #2563eb);
  border: none;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  margin-top: 20rpx;
  box-shadow: 0 6rpx 16rpx rgba(59, 130, 246, 0.4);
}

.login-btn:active {
  box-shadow: inset 0 4rpx 10rpx rgba(0, 0, 0, 0.3);
}

.login-btn::after {
  border: none;
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(59, 130, 246, 0.2);
  border-top-color: #3b82f6;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #94a3b8;
  margin-top: 24rpx;
}

/* 错误提示 */
.error-message {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: rgba(239, 68, 68, 0.1);
  border: 1rpx solid rgba(239, 68, 68, 0.3);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 30rpx;
  flex-wrap: wrap;
}

.error-icon {
  font-size: 32rpx;
}

.error-text {
  font-size: 26rpx;
  color: #ef4444;
  flex: 1;
}

.retry-btn {
  font-size: 24rpx;
  color: #3b82f6;
  background: transparent;
  border: none;
  padding: 8rpx 16rpx;
}

.retry-btn::after {
  border: none;
}
