.container {
  min-height: 100vh;
  background: #0f1419;
  padding: 30rpx;
  padding-bottom: 180rpx;
}

.user-card {
  width: calc(100% - 60rpx);
  margin: 0 auto 30rpx;
  background: linear-gradient(145deg, #23293a, #1a1f2e);
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  display: flex;
  align-items: center;
  gap: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  box-sizing: border-box;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #3b82f6, #2563eb);
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
}

.info {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.name {
  font-size: 36rpx;
  font-weight: bold;
  color: #f1f5f9;
}

.role-badge {
  display: inline-block;
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  width: fit-content;
}

.role-teacher {
  background: rgba(59, 130, 246, 0.15);
  color: #3b82f6;
}

.role-student {
  background: rgba(16, 185, 129, 0.15);
  color: #10b981;
}

.info-list {
  width: calc(100% - 60rpx);
  margin: 0 auto 40rpx;
  background: linear-gradient(145deg, #23293a, #1a1f2e);
  border-radius: 20rpx;
  padding: 20rpx 0;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  box-sizing: border-box;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 40rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #64748b;
}

.info-value {
  font-size: 28rpx;
  color: #f1f5f9;
  font-weight: 500;
}

.logout-btn {
  width: 100%;
  height: 96rpx;
  background: rgba(239, 68, 68, 0.15);
  border: 1rpx solid rgba(239, 68, 68, 0.2);
  border-radius: 48rpx;
  font-size: 32rpx;
  color: #ef4444;
}

.logout-btn:active {
  background: rgba(239, 68, 68, 0.2);
}

.logout-btn::after {
  border: none;
}
