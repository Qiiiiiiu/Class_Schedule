<view class="container">
  <view class="bind-code-section">
    <view class="section-header">
      <text class="section-title">绑定教师</text>
      <text class="section-desc">请输入教师提供的绑定码</text>
    </view>
    <view class="code-input-row">
      <input class="code-input" type="number" placeholder="请输入6位绑定码" maxlength="6" value="{{bindCode}}" bindinput="onBindCodeInput" />
      <button class="bind-btn {{bindCode.length === 6 ? 'active' : 'disabled'}}" bindtap="onVerifyBindCode" disabled="{{bindCode.length !== 6}}">绑定</button>
    </view>
  </view>

  <view class="teacher-list" wx:if="{{boundTeachers.length > 0}}">
    <view class="teacher-item" wx:for="{{boundTeachers}}" wx:key="_id">
      <view class="teacher-info">
        <view class="teacher-avatar"></view>
        <view class="teacher-text">
          <text class="teacher-name">{{item.teacherName}}</text>
          <text class="teacher-meta" wx:if="{{item.phone}}">{{item.phone}} | {{item.subject || '暂无科目'}}</text>
          <text class="teacher-meta" wx:else>{{item.subject || '暂无科目'}}</text>
        </view>
      </view>
      <view class="teacher-status status-approved">已绑定</view>
    </view>
  </view>

  <view class="empty-state" wx:else>
    <text class="empty-icon">👨‍🏫</text>
    <text class="empty-text">暂无已绑定教师</text>
  </view>

  <student-tab-bar active="teachers"></student-tab-bar>
</view>
