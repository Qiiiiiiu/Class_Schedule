.container {
  min-height: 100vh;
  background: #0f1419;
}

/* ===== 绑定码区 ===== */
.bind-code-section {
  background: linear-gradient(145deg, #23293a, #1a1f2e);
  padding: 40rpx 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.section-header {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #f1f5f9;
  display: block;
  margin-bottom: 8rpx;
}

.section-desc {
  font-size: 24rpx;
  color: #64748b;
}

.code-input-row {
  display: flex;
  gap: 20rpx;
}

.code-input {
  flex: 1;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 40rpx;
  padding: 0 40rpx;
  font-size: 32rpx;
  letter-spacing: 8rpx;
  text-align: center;
  color: #f1f5f9;
}

.bind-btn {
  height: 80rpx;
  padding: 0 40rpx;
  border: none;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #94a3b8;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.bind-btn.active {
  background: linear-gradient(145deg, #3b82f6, #2563eb);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.4);
}

.bind-btn.disabled {
  background: rgba(255, 255, 255, 0.03);
  color: #64748b;
}

/* ===== Tab ===== */
.tabs {
  background: #1a1f2e;
  display: flex;
  padding: 0 30rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #64748b;
  position: relative;
}

.tab-item.active {
  color: #3b82f6;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #3b82f6, #06b6d4);
  border-radius: 3rpx;
}

.badge {
  position: absolute;
  top: 20rpx;
  right: 30rpx;
  background: #ef4444;
  color: #ffffff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  min-width: 32rpx;
  text-align: center;
}

/* ===== 教师列表 ===== */
.teacher-list {
  background: linear-gradient(145deg, #23293a, #1a1f2e);
  border-radius: 20rpx;
  margin: 30rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.teacher-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.teacher-item:active {
  background: rgba(255, 255, 255, 0.03);
}

.teacher-item:last-child {
  border-bottom: none;
}

.teacher-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.teacher-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #3b82f6, #2563eb);
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.3);
}

.teacher-text {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.teacher-name {
  font-size: 30rpx;
  color: #f1f5f9;
  font-weight: 500;
}

.teacher-meta {
  font-size: 24rpx;
  color: #64748b;
}

.teacher-status {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.status-approved {
  background: rgba(16, 185, 129, 0.15);
  color: #10b981;
}

.status-pending {
  background: rgba(245, 158, 11, 0.15);
  color: #f59e0b;
}

.status-rejected {
  background: rgba(239, 68, 68, 0.15);
  color: #ef4444;
}

/* ===== 预约列表 ===== */
.application-list {
  padding: 30rpx;
}

.application-item {
  background: linear-gradient(145deg, #23293a, #1a1f2e);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.app-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.app-title {
  font-size: 30rpx;
  color: #f1f5f9;
  font-weight: 500;
}

.app-time {
  font-size: 24rpx;
  color: #64748b;
}

.app-status {
  font-size: 24rpx;
  margin-top: 8rpx;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  color: #64748b;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #64748b;
}
