.container {
  min-height: 100vh;
  background: #e8ecf1;
}

/* ===== Tab ===== */
.tabs {
  background: #e8ecf1;
  display: flex;
  padding: 0 30rpx;
  border-bottom: 1rpx solid rgba(0, 47, 167, 0.08);
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.04);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #5a6072;
  position: relative;
}

.tab-item.active {
  color: #002FA7;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: #002FA7;
  border-radius: 3rpx;
}

/* ===== 预约列表 ===== */
.application-list {
  padding: 30rpx;
}

.application-item {
  background: #e8ecf1;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 6rpx 6rpx 14rpx #d1d6dd, -6rpx -6rpx 14rpx #ffffff;
}

.app-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(0, 47, 167, 0.08);
}

.app-course {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1d28;
}

.app-status {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.status-pending {
  background: #fef3c7;
  color: #d97706;
}

.status-approved {
  background: #d1fae5;
  color: #059669;
}

.status-rejected {
  background: #fee2e2;
  color: #dc2626;
}

.app-details {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.detail-item {
  font-size: 26rpx;
  color: #5a6072;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #5a6072;
}
