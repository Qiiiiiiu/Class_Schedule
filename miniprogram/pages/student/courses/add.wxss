.container {
  min-height: 100vh;
  background: #0f1419;
  padding: 30rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.form-section {
  background: #1a1f2e;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  width: 90%;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.section-header {
  margin-bottom: 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
  padding-bottom: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #f1f5f9;
}

.form-item {
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.label {
  width: 180rpx;
  font-size: 28rpx;
  color: #94a3b8;
}

.content-wrap {
  flex: 1;
}

.input {
  background: #0f1419;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 8rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: #f1f5f9;
  height: 80rpx;
  box-sizing: border-box;
}

.picker-value {
  background: #0f1419;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 8rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: #f1f5f9;
  min-height: 80rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.price-input-wrap {
  position: relative;
}

.price-symbol {
  position: absolute;
  left: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  color: #3b82f6;
  font-size: 32rpx;
  font-weight: bold;
}

.price-input {
  padding-left: 60rpx;
}

.switch-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.switch-label {
  font-size: 28rpx;
  color: #94a3b8;
}

.time-picker {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.time-picker picker {
  flex: 1;
}

.time-separator {
  color: #64748b;
  font-size: 28rpx;
}

/* Weekday Picker */
.weekday-picker {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.weekday-item {
  width: 72rpx;
  height: 72rpx;
  background: #0f1419;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #94a3b8;
}

.weekday-item.selected {
  background: #3b82f6;
  color: #ffffff;
  border-color: #3b82f6;
  box-shadow: 0 2rpx 10rpx rgba(59, 130, 246, 0.4);
}

.repeat-count-wrap {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.repeat-count-input {
  width: 200rpx;
  text-align: center;
}

.repeat-count-tip {
  font-size: 24rpx;
  color: #64748b;
}

/* Calendar styling */
.select-calendar-view {
  background: #0f1419;
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  padding: 20rpx;
  box-sizing: border-box;
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.calendar-nav {
  padding: 0 20rpx;
}

.nav-btn {
  font-size: 48rpx;
  color: #3b82f6;
  font-weight: bold;
}

.calendar-title {
  font-size: 30rpx;
  color: #f1f5f9;
  font-weight: 600;
}

.calendar-weekdays {
  display: flex;
  margin-bottom: 12rpx;
}

.weekday-item {
  flex: 1;
  text-align: center;
}

.weekday {
  font-size: 24rpx;
  color: #64748b;
}

.calendar-grid {
  display: flex;
  flex-direction: column;
}

.calendar-row {
  display: flex;
}

.select-calendar-day-cell {
  flex: 1;
  height: 80rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  position: relative;
  box-sizing: border-box;
}

.day-number {
  font-size: 28rpx;
  color: #f1f5f9;
}

.select-calendar-day-cell.other-month .day-number {
  color: #334155;
}

.select-calendar-day-cell.today .day-number {
  color: #3b82f6;
  font-weight: bold;
}

.select-calendar-day-cell.selected {
  background: rgba(59, 130, 246, 0.2);
  border: 2rpx solid #3b82f6;
  border-radius: 12rpx;
}

.select-calendar-day-cell.selected .day-number {
  color: #3b82f6;
  font-weight: bold;
}

.add-course-btn-wrap {
  margin-top: 40rpx;
}

.add-course-btn {
  background: linear-gradient(145deg, #3b82f6, #2563eb) !important;
  color: #ffffff !important;
  font-size: 32rpx !important;
  font-weight: bold !important;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx !important;
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.3);
}