.container {
  min-height: 100vh;
  background: #0f1419;
  padding: 30rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.form-section {
  background: #1a1f2e;
  border-radius: 30rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  width: 90%;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.section-header {
  margin-bottom: 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
  padding-bottom: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #f1f5f9;
}

.section-desc {
  font-size: 22rpx;
  color: #64748b;
  margin-left: 10rpx;
}

/* Badge Styles */
.section-badge {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: bold;
}

.section-badge.student {
  background: rgba(59, 130, 246, 0.15);
  color: #3b82f6;
  border: 1rpx solid rgba(59, 130, 246, 0.3);
}

.section-badge.teacher {
  background: rgba(16, 185, 129, 0.15);
  color: #10b981;
  border: 1rpx solid rgba(16, 185, 129, 0.3);
}

/* Detail Display Mode */
.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.04);
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 28rpx;
  color: #94a3b8;
  flex-shrink: 0;
}

.detail-value {
  font-size: 28rpx;
  color: #f1f5f9;
  font-weight: 500;
  text-align: right;
  flex: 1;
  margin-left: 30rpx;
}

.price-text {
  color: #3b82f6;
  font-size: 32rpx;
  font-weight: bold;
}

/* Editable Form Mode */
.form-item {
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.label {
  width: 180rpx;
  font-size: 28rpx;
  color: #94a3b8;
}

.content-wrap {
  flex: 1;
}

.input {
  background: #0f1419;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 8rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: #f1f5f9;
  height: 80rpx;
  box-sizing: border-box;
}

.picker-value {
  background: #0f1419;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 8rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: #f1f5f9;
  min-height: 80rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.price-input-wrap {
  position: relative;
}

.price-symbol {
  position: absolute;
  left: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  color: #3b82f6;
  font-size: 32rpx;
  font-weight: bold;
}

.price-input {
  padding-left: 60rpx;
}

.time-picker {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.time-picker picker {
  flex: 1;
}

.time-separator {
  color: #64748b;
  font-size: 28rpx;
}

/* Calendar style rules */
.select-calendar-view {
  background: #0f1419;
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  padding: 20rpx;
  box-sizing: border-box;
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.calendar-nav {
  padding: 0 20rpx;
}

.nav-btn {
  font-size: 48rpx;
  color: #3b82f6;
  font-weight: bold;
}

.calendar-title {
  font-size: 30rpx;
  color: #f1f5f9;
  font-weight: 600;
}

.calendar-weekdays {
  display: flex;
  width: 100%;
  margin-bottom: 12rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
  padding-bottom: 12rpx;
}

.calendar-weekday-item {
  flex: 1;
  text-align: center;
}

.weekday {
  font-size: 24rpx;
  color: #64748b;
}

.calendar-grid {
  display: flex;
  flex-direction: column;
  width: 100%;
}

.calendar-row {
  display: flex;
  width: 100%;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.04);
}

.calendar-row:last-child {
  border-bottom: none;
}

.select-calendar-day-cell {
  flex: 1;
  height: 90rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  position: relative;
  box-sizing: border-box;
  border-right: 1rpx solid rgba(255, 255, 255, 0.04);
}

.select-calendar-day-cell:last-child {
  border-right: none;
}

.day-number {
  font-size: 28rpx;
  color: #f1f5f9;
}

.select-calendar-day-cell.other-month .day-number {
  color: #334155;
}

.select-calendar-day-cell.today .day-number {
  color: #3b82f6;
  font-weight: bold;
}

/* Highlights for schedules */
.select-calendar-day-cell.selected {
  background: rgba(59, 130, 246, 0.2);
  border: 2rpx solid #3b82f6;
  border-radius: 12rpx;
}

.select-calendar-day-cell.selected .day-number {
  color: #3b82f6;
  font-weight: bold;
}

/* Read-only highlights */
.select-calendar-day-cell.has-schedule {
  background: rgba(59, 130, 246, 0.08);
  border-radius: 8rpx;
}

.select-calendar-day-cell.has-schedule .day-number {
  color: #3b82f6;
  font-weight: bold;
}

.schedule-dot {
  width: 8rpx;
  height: 8rpx;
  background: #3b82f6;
  border-radius: 50%;
  position: absolute;
  bottom: 8rpx;
}

/* Action Buttons */
.actions-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 40rpx;
}

.action-btn {
  font-size: 30rpx !important;
  font-weight: bold !important;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx !important;
}

.edit-btn {
  background: linear-gradient(145deg, #3b82f6, #2563eb) !important;
  color: #ffffff !important;
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.3);
}

.delete-btn {
  background: rgba(239, 68, 68, 0.15) !important;
  color: #ef4444 !important;
  border: 1rpx solid rgba(239, 68, 68, 0.3) !important;
}

.save-btn {
  background: linear-gradient(145deg, #10b981, #059669) !important;
  color: #ffffff !important;
  box-shadow: 0 4rpx 16rpx rgba(16, 185, 129, 0.3);
}

.cancel-btn {
  background: rgba(255, 255, 255, 0.08) !important;
  color: #94a3b8 !important;
  border: 1rpx solid rgba(255, 255, 255, 0.1) !important;
}