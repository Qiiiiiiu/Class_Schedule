.container {
  min-height: 100vh;
  background: #0f1419;
  padding-bottom: calc(130rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* ===== Tab ===== */
.tabs {
  background: #1a1f2e;
  display: flex;
  padding: 0 30rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #64748b;
  position: relative;
}

.tab-item.active {
  color: #3b82f6;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #3b82f6, #06b6d4);
  border-radius: 3rpx;
}

/* ===== 课程列表 ===== */
.course-list {
  width: calc(100% - 60rpx);
  padding: 30rpx;
}

.course-item {
  background: linear-gradient(145deg, #23293a, #1a1f2e);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.course-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.course-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #f1f5f9;
}

.course-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.status-available {
  background: rgba(16, 185, 129, 0.15);
  color: #10b981;
}

.status-unavailable {
  background: rgba(255, 255, 255, 0.05);
  color: #64748b;
}

.course-info {
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-icon {
  font-size: 26rpx;
  color: #64748b;
}

.info-text {
  font-size: 26rpx;
  color: #94a3b8;
}

.course-actions {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 16rpx;
}

.applied-tag {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(16, 185, 129, 0.15);
  color: #10b981;
}

.subscribe-btn {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(59, 130, 246, 0.15);
  color: #3b82f6;
  border: 1rpx solid rgba(59, 130, 246, 0.3);
}

.subscribe-btn.subscribed {
  background: rgba(16, 185, 129, 0.15);
  color: #10b981;
  border: 1rpx solid rgba(16, 185, 129, 0.3);
}

.subscribe-btn::after {
  border: none;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  color: #64748b;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #64748b;
}

.add-floating-btn {
  position: fixed;
  right: 40rpx;
  bottom: calc(140rpx + env(safe-area-inset-bottom));
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(145deg, #3b82f6, #2563eb);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.4);
}

.add-floating-btn text {
  font-size: 60rpx;
  color: #ffffff;
  font-weight: 300;
  margin-top: -6rpx;
}
