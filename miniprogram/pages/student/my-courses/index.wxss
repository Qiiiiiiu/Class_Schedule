.container {
  min-height: 100vh;
  background: #e8ecf1;
}

/* ===== Tab ===== */
.tabs {
  background: #e8ecf1;
  display: flex;
  padding: 0 30rpx;
  border-bottom: 1rpx solid rgba(0, 47, 167, 0.08);
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.04);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #5a6072;
  position: relative;
}

.tab-item.active {
  color: #002FA7;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: #002FA7;
  border-radius: 3rpx;
}

/* ===== 课程列表 ===== */
.course-list {
  padding: 30rpx;
}

.course-item {
  background: #e8ecf1;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 6rpx 6rpx 14rpx #d1d6dd, -6rpx -6rpx 14rpx #ffffff;
}

.course-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(0, 47, 167, 0.08);
}

.course-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1d28;
}

.course-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.status-available {
  background: #d1fae5;
  color: #059669;
}

.status-unavailable {
  background: #e8ecf1;
  color: #5a6072;
  box-shadow: inset 2rpx 2rpx 4rpx #d1d6dd, inset -2rpx -2rpx 4rpx #ffffff;
}

.course-info {
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-icon {
  font-size: 26rpx;
}

.info-text {
  font-size: 26rpx;
  color: #5a6072;
}

.course-actions {
  display: flex;
  justify-content: flex-end;
}

.action-btn {
  height: 64rpx;
  padding: 0 30rpx;
  background: linear-gradient(145deg, #001a6e, #002FA7);
  border: none;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #ffffff;
  box-shadow: 4rpx 4rpx 8rpx rgba(0, 47, 167, 0.25), -2rpx -2rpx 4rpx rgba(255, 255, 255, 0.4);
}

.action-btn:active {
  box-shadow: inset 3rpx 3rpx 6rpx rgba(0, 0, 0, 0.25);
}

.applied-tag {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  background: #e8ecf1;
  color: #5a6072;
  box-shadow: inset 2rpx 2rpx 4rpx #d1d6dd, inset -2rpx -2rpx 4rpx #ffffff;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #5a6072;
}
