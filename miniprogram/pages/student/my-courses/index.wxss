.container {
  min-height: 100vh;
  background: #0f1419;
  padding-bottom: calc(130rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

/* ===== Tab 切换 ===== */
.tabs {
  background: #1a1f2e;
  display: flex;
  padding: 0 30rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
  width: 100%;
  box-sizing: border-box;
  z-index: 10;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #64748b;
  position: relative;
}

.tab-item.active {
  color: #3b82f6;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #3b82f6, #06b6d4);
  border-radius: 3rpx;
}

/* ===== 周历导航 ===== */
.week-nav {
  background: #1a1f2e;
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  width: 100%;
  box-sizing: border-box;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.week-nav-center {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 30rpx;
}

.nav-arrow {
  font-size: 48rpx;
  color: #3b82f6;
  padding: 10rpx 20rpx;
  line-height: 1;
}

.week-label {
  font-size: 30rpx;
  font-weight: bold;
  color: #f1f5f9;
}

/* ===== 周课表网格 ===== */
.schedule-scroll {
  flex: 1;
  width: 100%;
  height: calc(100vh - 240rpx - env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.schedule-grid {
  display: flex;
  background: #0f1419;
  width: 100%;
  box-sizing: border-box;
}

.time-column {
  width: 90rpx;
  flex-shrink: 0;
}

.time-header {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
  background: #101520;
}

.time-slot {
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #55657d;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.03);
  box-sizing: border-box;
}

.day-column {
  width: calc((100% - 90rpx) / 7);
  flex-shrink: 0;
  border-left: 1rpx solid rgba(255, 255, 255, 0.04);
}

.day-header {
  height: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
  background: #1a1f2e;
}

.day-header.today {
  background: rgba(59, 130, 246, 0.15);
  box-shadow: inset 0 0 20rpx rgba(59, 130, 246, 0.1);
}

.day-name {
  font-size: 24rpx;
  color: #94a3b8;
  font-weight: 500;
}

.day-date {
  font-size: 20rpx;
  color: #64748b;
  margin-top: 4rpx;
}

.day-header.today .day-name {
  color: #3b82f6;
  font-weight: bold;
}

.day-header.today .day-date {
  color: #f1f5f9;
}

.day-slots {
  position: relative;
  height: calc(120rpx * 18); /* 06:00 到 24:00 共 18 小时 */
  background: rgba(255, 255, 255, 0.01);
}

.schedule-item {
  position: absolute;
  left: 2rpx;
  right: 2rpx;
  border-radius: 8rpx;
  padding: 8rpx 4rpx;
  box-sizing: border-box;
  overflow: hidden;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.3);
  display: flex;
  flex-direction: column;
}

.course-name {
  display: block;
  font-size: 19rpx;
  font-weight: bold;
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.course-time, .course-room {
  display: block;
  font-size: 16rpx;
  margin-top: 4rpx;
  opacity: 0.8;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.1;
}

/* ===== 列表视图 ===== */
.list-scroll {
  flex: 1;
  width: 100%;
  height: calc(100vh - 120rpx - env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.course-list {
  padding: 30rpx;
  box-sizing: border-box;
}

.course-item {
  background: linear-gradient(145deg, #23293a, #1a1f2e);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.course-item:active {
  background: rgba(255, 255, 255, 0.03);
}

.course-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.course-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #f1f5f9;
}

.course-badge {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-left: 16rpx;
}

.course-badge.student {
  background: rgba(16, 185, 129, 0.15);
  color: #10b981;
  border: 1rpx solid rgba(16, 185, 129, 0.3);
}

.course-badge.teacher {
  background: rgba(59, 130, 246, 0.15);
  color: #3b82f6;
  border: 1rpx solid rgba(59, 130, 246, 0.3);
}

.course-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-left: auto;
}

.status-available {
  background: rgba(16, 185, 129, 0.15);
  color: #10b981;
}

.status-unavailable {
  background: rgba(255, 255, 255, 0.05);
  color: #64748b;
}

.course-info {
  margin-bottom: 10rpx;
}

.info-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-icon {
  font-size: 26rpx;
  color: #64748b;
}

.info-text {
  font-size: 26rpx;
  color: #94a3b8;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 150rpx 0;
  width: 100%;
}

.empty-icon {
  font-size: 100rpx;
  color: #64748b;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #64748b;
}

/* ===== 悬浮按钮 ===== */
.add-floating-btn {
  position: fixed;
  right: 40rpx;
  bottom: calc(150rpx + env(safe-area-inset-bottom));
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(145deg, #3b82f6, #2563eb);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 99;
  box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.4);
}

.add-floating-btn text {
  font-size: 60rpx;
  color: #ffffff;
  font-weight: 300;
  margin-top: -6rpx;
}

/* ===== 底部详情抽屉 ===== */
.course-detail {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
}

.detail-card {
  width: 100%;
  background: linear-gradient(145deg, #23293a, #1a1f2e);
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  box-shadow: 0 -8rpx 30rpx rgba(0, 0, 0, 0.4);
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.detail-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #f1f5f9;
}

.detail-close {
  font-size: 40rpx;
  color: #64748b;
  padding: 10rpx;
}

.detail-info {
  margin-bottom: 40rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.detail-label {
  font-size: 28rpx;
  color: #64748b;
}

.detail-value {
  font-size: 28rpx;
  color: #f1f5f9;
}

.detail-value.status-available {
  color: #10b981;
}

.detail-value.status-unavailable {
  color: #64748b;
}

.detail-actions {
  display: flex;
  gap: 20rpx;
}

.detail-btn {
  flex: 1;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 44rpx;
  font-size: 28rpx;
  color: #94a3b8;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-btn:active {
  background: rgba(255, 255, 255, 0.08);
}

/* 按钮特殊样式 */
.detail-btn.edit-btn {
  background: rgba(59, 130, 246, 0.15);
  color: #3b82f6;
  border: 1rpx solid rgba(59, 130, 246, 0.3);
}

.detail-btn.edit-btn:active {
  background: rgba(59, 130, 246, 0.25);
}

.detail-btn.delete-btn {
  background: rgba(239, 68, 68, 0.15);
  color: #ef4444;
  border: 1rpx solid rgba(239, 68, 68, 0.3);
}

.detail-btn.delete-btn:active {
  background: rgba(239, 68, 68, 0.25);
}

/* 订阅按钮首选样式 */
.detail-btn:first-child:not(.edit-btn):not(.delete-btn) {
  background: linear-gradient(145deg, #3b82f6, #2563eb);
  color: #ffffff;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.3);
}

.detail-btn:first-child:not(.edit-btn):not(.delete-btn):active {
  box-shadow: inset 0 4rpx 8rpx rgba(0, 0, 0, 0.3);
  opacity: 0.9;
}
