<view class="container">
  <view class="tabs">
    <view class="tab-item {{currentTab === 'all' ? 'active' : ''}}" bindtap="switchTab" data-tab="all">
      全部课程
    </view>
    <view class="tab-item {{currentTab === 'today' ? 'active' : ''}}" bindtap="switchTab" data-tab="today">
      今日课程
    </view>
    <view class="tab-item {{currentTab === 'week' ? 'active' : ''}}" bindtap="switchTab" data-tab="week">
      本周课程
    </view>
  </view>

  <view class="course-list" wx:if="{{displayCourses.length > 0}}">
    <view class="course-item" wx:for="{{displayCourses}}" wx:key="_id">
      <view class="course-header">
        <text class="course-name">{{item.name}}</text>
        <view class="course-status status-{{item.status}}">
          {{item.status === 'available' ? '进行中' : '已停课'}}
        </view>
      </view>
      <view class="course-info">
        <view class="info-row">
          <text class="info-icon">👨‍🏫</text>
          <text class="info-text">{{item.teacherName}}</text>
        </view>
        <view class="info-row">
          <text class="info-icon">📅</text>
          <text class="info-text">{{item.scheduleStr}}</text>
        </view>
        <view class="info-row">
          <text class="info-icon">📍</text>
          <text class="info-text">{{item.schedule.classroom || '未设置地点'}}</text>
        </view>
      </view>
      <view class="course-actions">
        <button class="action-btn" bindtap="onApplyCourse" data-course="{{item}}" wx:if="{{!item.applied}}">
          申请选课
        </button>
        <view class="applied-tag" wx:else>
          {{item.applicationStatus === 'pending' ? '申请中' : item.applicationStatus === 'approved' ? '已选课' : '已拒绝'}}
        </view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:else>
    <text class="empty-icon">📚</text>
    <text class="empty-text">{{emptyText}}</text>
  </view>
</view>