<view class="container">
  <view class="course-list" wx:if="{{courses.length > 0}}">
    <view class="course-item" wx:for="{{courses}}" wx:key="_id" bindtap="goToCourseDetail" data-id="{{item._id}}">
      <view class="course-header">
        <text class="course-name">{{item.name || item.courseName}}</text>
        <view class="course-status status-{{item.status}}">
          {{item.status === 'available' ? '进行中' : '已停课'}}
        </view>
      </view>
      <view class="course-info">
        <view class="info-row">
          <text class="info-icon">👨‍🏫</text>
          <text class="info-text">{{item.teacherName}}</text>
        </view>
        <view class="info-row">
          <text class="info-icon">📅</text>
          <text class="info-text">{{item.scheduleStr || (item.schedule.date + ' ' + item.schedule.startTime + '-' + item.schedule.endTime)}}</text>
        </view>
        <view class="info-row">
          <text class="info-icon">📍</text>
          <text class="info-text">{{item.schedule.classroom || '未设置地点'}}</text>
        </view>
      </view>
      <view class="course-actions">
        <button class="subscribe-btn {{item.subscribed ? 'subscribed' : ''}}" 
                bindtap="onToggleSubscribe" 
                data-schedule-id="{{item.scheduleId}}"
                data-subscribed="{{item.subscribed}}">
          {{item.subscribed ? '🔔 已订阅' : '🔕 订阅提醒'}}
        </button>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:else>
    <text class="empty-icon">📚</text>
    <text class="empty-text">{{emptyText}}</text>
  </view>

  <view class="add-floating-btn" bindtap="onAddCourse">
    <text>+</text>
  </view>

  <student-tab-bar active="my-courses"></student-tab-bar>
</view>