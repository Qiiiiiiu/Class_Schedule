<view class="container">
  <view class="header">
    <view class="welcome">
      <text class="title">您好，{{userInfo.name}}</text>
      <text class="subtitle">欢迎使用课程管理系统</text>
    </view>
    <image class="avatar" src="{{userInfo.avatar || '/images/icons/avatar.png'}}" mode="aspectFill"></image>
  </view>

  <view class="stats-grid">
    <view class="stat-card" bindtap="goToTeachers">
      <view class="stat-icon">👨‍🏫</view>
      <view class="stat-info">
        <text class="stat-num">{{stats.teacherCount}}</text>
        <text class="stat-label">绑定教师</text>
      </view>
    </view>

    <view class="stat-card" bindtap="goToMyCourses">
      <view class="stat-icon">📚</view>
      <view class="stat-info">
        <text class="stat-num">{{stats.courseCount}}</text>
        <text class="stat-label">我的课程</text>
      </view>
    </view>

  </view>

  <view class="quick-actions">
    <text class="section-title">快捷操作</text>
    <view class="action-list">
      <view class="action-item" bindtap="goToTeachers">
        <text class="action-icon">🔍</text>
        <text class="action-text">查找教师</text>
      </view>
      <view class="action-item" bindtap="goToMyCourses">
        <text class="action-icon">📖</text>
        <text class="action-text">我的课程</text>
      </view>
    </view>
  </view>

  <view class="course-list" wx:if="{{todayCourses.length > 0}}">
    <text class="section-title">今日课程</text>
    <view class="course-item" wx:for="{{todayCourses}}" wx:key="_id">
      <view class="course-info">
        <text class="course-name">{{item.name}}</text>
        <text class="course-time">🕐 {{item.schedule.startTime}} - {{item.schedule.endTime}}</text>
        <text class="course-room">📍 {{item.schedule.classroom || '未设置地点'}}</text>
      </view>
      <view class="course-teacher">
        <text class="teacher-name">{{item.teacherName}}</text>
      </view>
    </view>
  </view>

  <student-tab-bar active="home"></student-tab-bar>
</view>
