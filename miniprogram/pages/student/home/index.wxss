.container {
  min-height: 100vh;
  background: #0f1419;
  padding: 30rpx;
  padding-top: 0;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 60rpx 20rpx 40rpx;
}

.welcome {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #f1f5f9;
}

.subtitle {
  font-size: 26rpx;
  color: #94a3b8;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #3b82f6, #2563eb);
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
}

/* ===== 统计卡片 ===== */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  padding: 0 10rpx;
}

.stat-card {
  background: linear-gradient(145deg, #23293a, #1a1f2e);
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.stat-icon {
  font-size: 50rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(59, 130, 246, 0.12);
  border-radius: 12rpx;
}

.stat-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.stat-num {
  font-size: 44rpx;
  font-weight: bold;
  color: #f1f5f9;
}

.stat-label {
  font-size: 24rpx;
  color: #64748b;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #f1f5f9;
  display: block;
  margin-bottom: 24rpx;
}

/* ===== 快捷操作 ===== */
.quick-actions {
  margin-top: 50rpx;
  padding: 0 10rpx;
}

.action-list {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.action-item {
  background: linear-gradient(145deg, #23293a, #1a1f2e);
  border-radius: 16rpx;
  padding: 30rpx 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.25);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.action-item:active {
  box-shadow: inset 0 4rpx 12rpx rgba(0, 0, 0, 0.4);
}

.action-icon {
  font-size: 40rpx;
  color: #3b82f6;
}

.action-text {
  font-size: 22rpx;
  color: #94a3b8;
}

/* ===== 课程列表 ===== */
.course-list {
  margin-top: 50rpx;
  padding: 0 10rpx;
}

.course-item {
  background: linear-gradient(145deg, #23293a, #1a1f2e);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.course-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.course-name {
  font-size: 30rpx;
  color: #f1f5f9;
  font-weight: 500;
}

.course-time,
.course-room {
  font-size: 24rpx;
  color: #64748b;
}

.course-teacher {
  text-align: right;
}

.teacher-name {
  font-size: 26rpx;
  color: #3b82f6;
}
