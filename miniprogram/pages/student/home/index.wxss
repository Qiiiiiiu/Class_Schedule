.container {
  min-height: 100vh;
  background: #0f1419;
  padding: 30rpx;
  padding-top: 0;
  padding-bottom: calc(130rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  width: 100%;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 60rpx 10rpx 40rpx;
}

.welcome {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #f1f5f9;
}

.subtitle {
  font-size: 26rpx;
  color: #94a3b8;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #3b82f6, #2563eb);
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.4);
}



.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #f1f5f9;
  display: block;
  margin-bottom: 24rpx;
  padding-left: 10rpx;
}

/* ===== 月历概览区 ===== */
.calendar-section {
  background: linear-gradient(145deg, #1e2433, #161a26);
  border-radius: 24rpx;
  padding: 30rpx 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  margin-bottom: 40rpx;
}

.section-header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding: 0 10rpx;
}

.section-header-row .section-title {
  padding-left: 0;
  margin-bottom: 0;
}

.calendar-nav-wrap {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.calendar-nav {
  font-size: 40rpx;
  color: #3b82f6;
  padding: 0 16rpx;
  font-weight: bold;
  line-height: 1;
}

.calendar-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #f1f5f9;
}

.calendar-weekdays {
  display: flex;
  margin-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
  padding-bottom: 12rpx;
}

.weekday-item {
  flex: 1;
  text-align: center;
}

.weekday {
  font-size: 24rpx;
  color: #64748b;
  font-weight: 500;
}

.calendar-grid {
  display: flex;
  flex-wrap: wrap;
  width: 100%;
}

.calendar-day {
  width: 14.28%;
  height: 90rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  box-sizing: border-box;
  border-radius: 12rpx;
  margin-bottom: 6rpx;
  border: 1rpx solid transparent;
}

.calendar-day.empty {
  background: transparent !important;
}

.calendar-day.today-cell {
  border: 1rpx dashed rgba(59, 130, 246, 0.5);
}

.day-num {
  font-size: 26rpx;
  color: #f1f5f9;
}

.day-num.today {
  color: #3b82f6;
  font-weight: bold;
}

.day-count {
  font-size: 16rpx;
  margin-top: 4rpx;
  font-weight: bold;
}

/* ===== 今日日程焦点卡片 ===== */
.quick-peek-section {
  margin-bottom: 40rpx;
}

.focus-card {
  border-radius: 24rpx;
  padding: 40rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 12rpx 36rpx rgba(0, 0, 0, 0.35);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

/* 焦点卡片三种状态渐变底色 */
.focus-card.in-progress {
  background: linear-gradient(135deg, #1e40af, #3b82f6);
}

.focus-card.upcoming {
  background: linear-gradient(135deg, #2e1065, #6d28d9);
}

.focus-card.finished {
  background: linear-gradient(135deg, #1f2937, #374151);
  opacity: 0.8;
}

.focus-badge {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: bold;
  background: rgba(255, 255, 255, 0.2);
  color: #ffffff;
}

.focus-course-name {
  font-size: 38rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 24rpx;
  max-width: 80%;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.focus-meta-row {
  display: flex;
  gap: 30rpx;
  margin-bottom: 30rpx;
}

.meta-item {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.focus-teacher-row {
  display: flex;
  align-items: center;
  border-top: 1rpx solid rgba(255, 255, 255, 0.15);
  padding-top: 24rpx;
  gap: 8rpx;
}

.focus-teacher-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.focus-teacher-val {
  font-size: 26rpx;
  font-weight: bold;
  color: #ffffff;
}

.source-tag {
  font-size: 18rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-left: auto;
}

.source-tag.student {
  background: rgba(16, 185, 129, 0.2);
  color: #34d399;
  border: 1rpx solid rgba(16, 185, 129, 0.3);
}

.source-tag.teacher {
  background: rgba(59, 130, 246, 0.25);
  color: #93c5fd;
  border: 1rpx solid rgba(59, 130, 246, 0.3);
}

/* 无课放松卡片 */
.relax-card {
  background: linear-gradient(145deg, #1b2030, #131722);
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  text-align: center;
  box-shadow: inset 0 0 20rpx rgba(255, 255, 255, 0.02);
  border: 1rpx solid rgba(255, 255, 255, 0.04);
}

.relax-icon {
  font-size: 70rpx;
}

.relax-text {
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.5;
}

/* ===== 今日横向滑动卡片 (多门课) ===== */
.today-list-section {
  margin-bottom: 40rpx;
  padding: 0 10rpx;
}

.sub-section-title {
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 16rpx;
  font-weight: bold;
  display: block;
}

.horizontal-scroll {
  white-space: nowrap;
  width: 100%;
}

.scroll-item {
  display: inline-block;
  width: 320rpx;
  background: #1a1f2e;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-right: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  vertical-align: top;
  box-sizing: border-box;
}

.scroll-item:last-child {
  margin-right: 0;
}

.scroll-item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.scroll-course-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #f1f5f9;
  max-width: 70%;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.scroll-status-tag {
  font-size: 16rpx;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #94a3b8;
}

.scroll-item.in-progress .scroll-status-tag {
  background: rgba(16, 185, 129, 0.15);
  color: #10b981;
}

.scroll-item.upcoming .scroll-status-tag {
  background: rgba(59, 130, 246, 0.15);
  color: #3b82f6;
}

.scroll-time, .scroll-room {
  display: block;
  font-size: 20rpx;
  color: #64748b;
  margin-top: 4rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ===== 未来三天时间轴 ===== */
.upcoming-section {
  margin-bottom: 40rpx;
}

.timeline {
  padding: 10rpx;
  display: flex;
  flex-direction: column;
}

.timeline-day {
  position: relative;
  padding-left: 40rpx;
  margin-bottom: 30rpx;
}

.timeline-day:last-child {
  margin-bottom: 0;
}

.timeline-day::before {
  content: '';
  position: absolute;
  left: 10rpx;
  top: 36rpx;
  bottom: -36rpx;
  width: 2rpx;
  background: rgba(255, 255, 255, 0.08);
}

.timeline-day:last-child::before {
  display: none;
}

.timeline-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.timeline-dot {
  position: absolute;
  left: 4rpx;
  top: 10rpx;
  width: 14rpx;
  height: 14rpx;
  background: #3b82f6;
  border-radius: 50%;
  box-shadow: 0 0 10rpx rgba(59, 130, 246, 0.6);
}

.timeline-date {
  font-size: 26rpx;
  font-weight: bold;
  color: #94a3b8;
}

.timeline-count-tag {
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
  background: rgba(59, 130, 246, 0.12);
  color: #3b82f6;
  font-weight: 500;
}

.timeline-free-tag {
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  color: #64748b;
}

.timeline-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.timeline-course-card {
  background: linear-gradient(145deg, #1b2030, #131722);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.04);
}

.course-main-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.upcoming-course-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #f1f5f9;
}

.upcoming-course-time {
  font-size: 22rpx;
  color: #3b82f6;
  font-weight: bold;
}

.course-sub-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.upcoming-course-room, .upcoming-course-teacher {
  font-size: 20rpx;
  color: #64748b;
}

.timeline-empty-card {
  background: rgba(255, 255, 255, 0.015);
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
  font-size: 22rpx;
  color: #55657d;
  border: 1rpx dashed rgba(255, 255, 255, 0.04);
}


