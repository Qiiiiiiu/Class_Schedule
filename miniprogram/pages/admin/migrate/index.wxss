.container {
  min-height: 100vh;
  background: #0f1419;
  padding: 30rpx;
  padding-bottom: 180rpx;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #f1f5f9;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: #64748b;
}

.stats-card {
  display: flex;
  justify-content: space-around;
  background: linear-gradient(145deg, #23293a, #1a1f2e);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #3b82f6;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #94a3b8;
}

.migrate-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(145deg, #3b82f6, #2563eb);
  border: none;
  border-radius: 48rpx;
  font-size: 32rpx;
  color: #ffffff;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.4);
}

.migrate-btn.loading {
  opacity: 0.7;
}

.migrate-btn::after {
  border: none;
}

.log-section {
  background: linear-gradient(145deg, #23293a, #1a1f2e);
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.log-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #f1f5f9;
  margin-bottom: 20rpx;
}

.log-content {
  height: 400rpx;
  background: rgba(0, 0, 0, 0.2);
  border-radius: 12rpx;
  padding: 20rpx;
}

.log-item {
  font-size: 24rpx;
  color: #94a3b8;
  padding: 8rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.log-item:last-child {
  border-bottom: none;
}
